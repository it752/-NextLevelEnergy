---
import { Image } from 'astro:assets';
import logoWhite from '../assets/logo/logo-white.svg';
import LazyHyperspeed from './LazyHyperspeed.tsx';
---

<section id="hero-next">
	<!-- Preloader (Curtain Effect) -->
	<div id="preloader" class="preloader">
		<div class="preloader-panel left-panel"></div>
		<div class="preloader-panel right-panel"></div>
		<div class="preloader-center">
			<Image src={logoWhite} alt="NF Logo" class="preloader-logo" loading="eager" />
			<div class="loading-line"></div>
		</div>
	</div>

	<!-- Fixed Branding & Navigation (Restored) -->
	<nav class="navbar" id="global-nav">
		<a href="/" class="logo-link" aria-label="Strona główna">
			<Image src={logoWhite} alt="NF Logo" class="logo-img" loading="eager" />
		</a>
		<button id="menu-toggle" class="menu-btn" aria-label="Otwórz menu">
			<span class="bar bar-long"></span>
			<span class="bar bar-short"></span>
			<span class="bar bar-long"></span>
		</button>
	</nav>

	<!-- Menu Overlay (Restored) -->
	<div id="menu-overlay" class="menu-overlay">
		<div class="menu-header">
			<Image src={logoWhite} alt="NF Logo" class="logo-img" />
			<button id="close-menu" class="close-btn" aria-label="Zamknij menu">
				<svg viewBox="0 0 24 24" width="32" height="32" stroke="white" stroke-width="2" fill="none">
					<path d="M18 6L6 18M6 6l12 12"></path>
				</svg>
			</button>
		</div>

		<div class="menu-links">
			{
				[
					{ label: 'Idea', href: '#idea' },
					{ label: 'Historia', href: '#history' },
					{ label: 'Zespół', href: '#team' },
					{ label: 'Ścieżka kariery', href: '#ścieżka-kariery' },
					{ label: 'Kariera', href: '#kariera' },
					{ label: 'Kontakt', href: '#contact' },
				].map((item, index) => (
					<a href={item.href} class="menu-item-link" style={`--index: ${index}`}>
						<span class="menu-item-text">{item.label}</span>
						<svg
							class="menu-item-arrow"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2">
							<path d="M5 12h14m-7-7l7 7-7 7" />
						</svg>
					</a>
				))
			}
		</div>
	</div>

	<!-- Dashboard Container -->
	<!-- Background Texture & Glows -->
	<div class="dashboard-bg">
		<LazyHyperspeed
			client:only="react"
			effectOptions={{
				onSpeedUp: () => {},
				onSlowDown: () => {},
				distortion: 'turbulentDistortion',
				length: 400,
				roadWidth: 10,
				islandWidth: 2,
				lanesPerRoad: 3,
				fov: 90,
				fovSpeedUp: 150,
				speedUp: 2,
				carLightsFade: 0.4,
				totalSideLightSticks: 20,
				lightPairsPerRoadWay: 40,
				shoulderLinesWidthPercentage: 0.05,
				brokenLinesWidthPercentage: 0.1,
				brokenLinesLengthPercentage: 0.5,
				lightStickWidth: [0.12, 0.5],
				lightStickHeight: [1.3, 1.7],
				movingAwaySpeed: [60, 80],
				movingCloserSpeed: [-120, -160],
				carLightsLength: [12, 80],
				carLightsRadius: [0.05, 0.14],
				carWidthPercentage: [0.3, 0.5],
				carShiftX: [-0.8, 0.8],
				carFloorSeparation: [0, 5],
				colors: {
					roadColor: 526344,
					islandColor: 657930,
					background: 0x0b111d,
					shoulderLines: 1250072,
					brokenLines: 1250072,
					leftCars: [14177983, 6770850, 12732332],
					rightCars: [242627, 941733, 3294549],
					sticks: 242627,
				},
			}}
		/>
	</div>

	<!-- Dashboard Content -->
	<div class="dash-content-wrapper hero-content-anim">
		<!-- Centered Text Column -->
		<div class="dash-text-col">
			<h1 class="main-heading">
				<span class="heading-line line-1">Nowa Era</span>
				<span class="heading-line line-2">
					<span class="gradient-text">Efektywności</span>
				</span>
				<span class="heading-line line-3">Energetycznej</span>
			</h1>

			<!-- Restored CTA Button -->
			<div class="btn-container">
				<a href="#idea" class="level-up-btn">
					<span class="btn-text">
						Level Up
						<svg
							class="arrow-svg"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="3"
							stroke-linecap="round"
							stroke-linejoin="round">
							<path d="M7 11l5-5 5 5"></path>
							<path d="M7 18l5-5 5 5"></path>
						</svg>
					</span>
				</a>
			</div>
		</div>
	</div>
</section>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		// Płynne ładowanie (Preloader)
		document.body.style.overflow = 'hidden';

		setTimeout(() => {
			const preloader = document.getElementById('preloader');
			if (preloader) {
				preloader.classList.add('hide');
				document.body.style.overflow = '';

				const animContainer = document.querySelector('.hero-content-anim');
				if (animContainer) {
					animContainer.classList.add('animate-in');
				}
			}
		}, 800);

		// Navbar Original Scripts
		const menuToggle = document.getElementById('menu-toggle');
		const closeMenu = document.getElementById('close-menu');
		const menuOverlay = document.getElementById('menu-overlay');

		if (menuToggle && closeMenu && menuOverlay) {
			const toggleScrollLock = (lock: boolean) => {
				document.body.style.overflow = lock ? 'hidden' : '';
			};

			menuToggle.addEventListener('click', () => {
				menuOverlay.classList.add('active');
				toggleScrollLock(true);
			});

			closeMenu.addEventListener('click', () => {
				menuOverlay.classList.remove('active');
				toggleScrollLock(false);
			});

			// Close menu on link click
			const menuLinks = menuOverlay.querySelectorAll('.menu-item-link');
			menuLinks.forEach(link => {
				link.addEventListener('click', () => {
					menuOverlay.classList.remove('active');
					toggleScrollLock(false);
				});
			});

			// Apple-style Smart Navbar
			let lastScroll = 0;
			const nav = document.getElementById('global-nav');

			if (nav) {
				window.addEventListener(
					'scroll',
					() => {
						const currentScroll = window.pageYOffset;

						// Always show at top
						if (currentScroll <= 100) {
							nav.classList.remove('navbar-hidden');
							nav.classList.remove('navbar-scrolled');
							return;
						}

						// Background state when scrolled
						if (currentScroll > 100) {
							nav.classList.add('navbar-scrolled');
						}

						// Scroll direction logic
						if (
							currentScroll > lastScroll &&
							!nav.classList.contains('navbar-hidden') &&
							currentScroll > 200
						) {
							// Scrolling down - hide
							nav.classList.add('navbar-hidden');
						} else if (currentScroll < lastScroll && nav.classList.contains('navbar-hidden')) {
							// Scrolling up - show
							nav.classList.remove('navbar-hidden');
						}

						lastScroll = currentScroll;
					},
					{ passive: true },
				);
			}
		}
	});
</script>

<style>
	#hero-next {
		width: 100%;
		height: 100vh;
		height: 100svh;
		background-color: #020202; /* Very dark outside background */
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 2rem;
		overflow: hidden;
		position: relative;
	}

	/* FIXED NAVBAR RESTORED */
	.navbar {
		position: fixed;
		top: 0;
		left: 0;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1.5rem;
		width: 100%;
		z-index: 2000;
		transition: all 0.4s cubic-bezier(0.19, 1, 0.22, 1);
		background: transparent;
	}

	/* Keep desktop nav inside the dashboard padding gap initially */
	@media (min-width: 1024px) {
		.navbar {
			left: 2rem;
			top: 2rem;
			width: calc(100% - 4rem);
			padding: 2rem 4rem;
			border-radius: 40px 40px 0 0;
		}
	}

	.navbar.navbar-scrolled {
		top: 0;
		left: 0;
		width: 100%;
		background: rgba(11, 17, 29, 0.8);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		padding: 1rem 1.5rem;
		border-radius: 0; /* Removing border radius when it sticks */
	}

	@media (min-width: 1024px) {
		.navbar.navbar-scrolled {
			padding: 1rem 4rem;
		}
	}

	.navbar.navbar-hidden {
		transform: translateY(-100%);
	}

	.logo-img {
		height: 2rem;
		width: auto;
		transition: height 0.3s ease;
	}

	.menu-btn,
	.close-btn {
		display: flex;
		align-items: center;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.5rem;
		width: 3rem;
		height: 3rem;
	}

	.menu-btn {
		flex-direction: column;
		align-items: flex-end;
		justify-content: center;
		gap: 6px;
	}

	.close-btn {
		justify-content: center;
	}

	.bar {
		height: 2.5px;
		background-color: white;
		border-radius: 99px;
		transition: width 0.3s ease;
	}

	.bar-long {
		width: 32px;
	}
	.bar-short {
		width: 20px;
	}

	.menu-btn:hover .bar-long {
		width: 20px;
	}
	.menu-btn:hover .bar-short {
		width: 32px;
	}

	/* MENU OVERLAY RESTORED */
	.menu-overlay {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100vh;
		height: 100svh;
		background-color: #0b111d;
		z-index: 3000;
		display: flex;
		flex-direction: column;
		opacity: 0;
		visibility: hidden;
		clip-path: circle(0% at 92% 4%);
		transition:
			clip-path 0.8s cubic-bezier(0.19, 1, 0.22, 1),
			opacity 0.4s ease,
			visibility 0.8s;
	}

	.menu-overlay.active {
		opacity: 1;
		visibility: visible;
		clip-path: circle(150% at 92% 4%);
	}

	.menu-header {
		opacity: 0;
		transform: translateY(-20px);
		transition: all 0.6s cubic-bezier(0.19, 1, 0.22, 1) 0.2s;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1.5rem;
		width: 100%;
	}

	.menu-overlay.active .menu-header {
		opacity: 1;
		transform: translateY(0);
	}

	.menu-links {
		flex: 1;
		display: flex;
		flex-direction: column;
		padding: 0;
	}

	.menu-item-link {
		flex: 1;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0 2.5rem;
		text-decoration: none;
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
		position: relative;
		overflow: hidden;
		opacity: 0;
		transform: translateY(30px);
		transition:
			opacity 0.8s cubic-bezier(0.19, 1, 0.22, 1),
			transform 0.8s cubic-bezier(0.19, 1, 0.22, 1);
		transition-delay: calc(0.3s + (var(--index) * 0.08s));
	}

	.menu-overlay.active .menu-item-link {
		opacity: 1;
		transform: translateY(0);
	}

	.menu-item-text {
		font-size: clamp(2rem, 8vw, 5rem);
		font-family: 'Outfit', sans-serif;
		font-weight: 900;
		text-transform: uppercase;
		color: transparent;
		-webkit-text-stroke: 1.5px rgba(255, 255, 255, 0.4);
		position: relative;
		z-index: 2;
		transition: all 0.4s ease;
	}

	.menu-item-link::before {
		content: '';
		position: absolute;
		top: 0;
		left: -100%;
		width: 100%;
		height: 100%;
		background: linear-gradient(90deg, #a213da 0%, rgba(162, 19, 218, 0) 100%);
		transition: left 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
		z-index: 1;
	}

	.menu-item-link:hover::before {
		left: 0;
	}
	.menu-item-link:hover .menu-item-text {
		color: white;
		-webkit-text-stroke: 1.5px transparent;
		padding-left: 1rem;
	}

	.menu-item-arrow {
		width: 3rem;
		height: 3rem;
		color: white;
		opacity: 0;
		transform: translateX(-20px);
		transition: all 0.4s ease;
		z-index: 2;
	}

	.menu-item-link:hover .menu-item-arrow {
		opacity: 1;
		transform: translateX(0);
	}

	/* Preloader */
	.preloader {
		position: fixed;
		inset: 0;
		z-index: 10000;
		display: flex;
		justify-content: center;
		align-items: center;
		pointer-events: none;
	}
	.preloader-panel {
		position: absolute;
		top: 0;
		width: 50vw;
		height: 100vh;
		background-color: #050505;
		transition: transform 1.2s cubic-bezier(0.8, 0, 0.1, 1);
		will-change: transform;
	}
	.left-panel {
		left: 0;
		border-right: 1px solid rgba(255, 255, 255, 0.05);
	}
	.right-panel {
		right: 0;
	}
	.preloader.hide .left-panel {
		transform: translateX(-100%);
	}
	.preloader.hide .right-panel {
		transform: translateX(100%);
	}
	.preloader-center {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5rem;
		transition: opacity 0.4s ease;
	}
	.preloader.hide .preloader-center {
		opacity: 0;
	}
	.preloader-logo {
		height: 30px;
		width: auto;
		filter: drop-shadow(0 0 10px rgba(255, 255, 255, 0.3));
	}
	.loading-line {
		width: 140px;
		height: 2px;
		background: rgba(255, 255, 255, 0.1);
		position: relative;
		overflow: hidden;
		border-radius: 2px;
	}
	.loading-line::after {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		bottom: 0;
		width: 30%;
		background: #a213da;
		animation: loading-bar 1.5s infinite ease-in-out;
		border-radius: 2px;
	}
	@keyframes loading-bar {
		0% {
			transform: translateX(-100%);
		}
		100% {
			transform: translateX(350%);
		}
	}

	/* Dashboard Background Layer */
	.dashboard-bg {
		position: absolute;
		inset: 0;
		z-index: 0;
		pointer-events: none;
	}
	.bg-texture {
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0.15;
		mix-blend-mode: color-dodge;
	}
	.glow-sphere {
		position: absolute;
		border-radius: 50%;
		filter: blur(100px);
		opacity: 0.5;
		will-change: transform;
	}
	.sphere-1 {
		width: 800px;
		height: 800px;
		background: radial-gradient(circle, rgba(162, 19, 218, 0.8) 0%, rgba(162, 19, 218, 0) 70%);
		right: 10%;
		top: 30%;
		transform: translate(0, -50%);
		animation: float-pulse 12s infinite alternate ease-in-out;
	}
	.sphere-2 {
		width: 600px;
		height: 600px;
		background: radial-gradient(circle, rgba(255, 0, 85, 0.6) 0%, rgba(255, 0, 85, 0) 70%);
		left: 10%;
		bottom: 10%;
		animation: float-pulse-reverse 15s infinite alternate ease-in-out;
	}
	.noise-overlay {
		position: absolute;
		inset: 0;
		background-image: url('data:image/svg+xml,%3Csvg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"%3E%3Cfilter id="noiseFilter"%3E%3CfeTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/%3E%3C/filter%3E%3Crect width="100%25" height="100%25" filter="url(%23noiseFilter)"/%3E%3C/svg%3E');
		opacity: 0.03;
		mix-blend-mode: overlay;
	}

	@keyframes float-pulse {
		0% {
			transform: translate(0, -50%) scale(1);
			opacity: 0.4;
		}
		100% {
			transform: translate(-50px, -40%) scale(1.1);
			opacity: 0.6;
		}
	}
	@keyframes float-pulse-reverse {
		0% {
			transform: translate(0, 0) scale(1.1);
			opacity: 0.5;
		}
		100% {
			transform: translate(50px, -20px) scale(1);
			opacity: 0.3;
		}
	}

	/* Desktop Layout Content */
	.dash-content-wrapper {
		width: 100vw;
		min-height: 100vh;
		min-height: 100lvh;
		position: relative;
		z-index: 10;
		display: flex;
		padding: 0 2rem;
		align-items: center;
		justify-content: center;
		pointer-events: none;
	}

	/* Typography & Animations */
	.dash-text-col {
		width: 100%;
		max-width: 800px;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 2.5rem;
		opacity: 0;
		transform: translateY(40px);
		pointer-events: auto;
	}
	.dash-person-col {
		width: 45%;
		height: 100%;
		position: absolute;
		right: 0;
		top: 0;
		opacity: 0;
		transform: translateX(40px);
		pointer-events: none;
	}
	.hero-content-anim.animate-in .dash-text-col {
		animation: fadeUp 1.2s cubic-bezier(0.19, 1, 0.22, 1) forwards 0.8s;
	}
	.hero-content-anim.animate-in .dash-person-col {
		animation: fadeLeft 1.2s cubic-bezier(0.19, 1, 0.22, 1) forwards 1s;
	}

	@keyframes fadeUp {
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
	@keyframes fadeLeft {
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}

	.main-heading {
		font-size: clamp(3.5rem, 6.5vw, 6.5rem);
		font-weight: 850;
		line-height: 1.05;
		letter-spacing: -0.04em;
		display: flex;
		flex-direction: column;
	}
	.heading-line {
		display: block;
	}

	/* Dodałem flex dla linii z Efektywnością aby trzymać sparkle zablokowany idealnie obok */
	.heading-line.line-2 {
		display: flex;
		align-items: center;
		flex-wrap: nowrap;
	}

	.gradient-text {
		color: #a213da;
		display: inline-block;
		padding-right: 15px; /* Wiekszy padding żeby sparkle mial miejsce i nie uciekał za border */
	}
	.sparkle-icon {
		flex-shrink: 0; /* Zapewnia że ikona nie zostanie zgnieciona */
		display: block;
		margin-top: -10px;
		animation: spin-slow 8s infinite linear;
	}
	@keyframes spin-slow {
		100% {
			transform: rotate(360deg);
		}
	}

	/* CTA BUTTON RESTORED */
	.btn-container {
		padding: 2.5rem 0 0 0;
		display: flex;
		justify-content: center;
		position: relative;
		z-index: 30;
	}

	.level-up-btn {
		display: inline-flex;
		align-items: center;
		padding: 0.9rem 2.2rem;
		border-radius: 9999px;
		border: 1px solid rgba(255, 255, 255, 0.25);
		background: rgba(255, 255, 255, 0.1);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		color: white;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		font-size: 0.8rem;
		transition:
			transform 0.3s ease,
			background 0.3s ease,
			box-shadow 0.3s ease;
		text-decoration: none;
	}

	.level-up-btn:hover {
		background: rgba(255, 255, 255, 0.2);
		transform: translateY(-2px);
		box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
	}

	.btn-text {
		display: flex;
		align-items: center;
		gap: 0.8rem;
	}

	.arrow-svg {
		width: 1rem;
		height: 1rem;
		animation: bounce-up 2s infinite ease-in-out;
	}

	@keyframes bounce-up {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-4px);
		}
	}

	/* Person Display */
	.person-img-wrapper {
		position: absolute;
		bottom: -5px;
		right: 10%;
		height: 105%;
		display: flex;
		align-items: flex-end;
		justify-content: center;
		mask-image: linear-gradient(to top, transparent 0%, black 5%, black 100%);
		-webkit-mask-image: linear-gradient(to top, transparent 0%, black 5%, black 100%);
	}
	.dash-person {
		height: 100%;
		width: auto;
		object-fit: contain;
		object-position: bottom;
		filter: drop-shadow(-30px 10px 40px rgba(0, 0, 0, 0.6));
	}

	/* Card inside Right Column */
	.floating-glass-card {
		position: absolute;
		bottom: 6rem;
		left: 0;
		width: 340px;
		background: rgba(11, 17, 29, 0.4);
		backdrop-filter: blur(30px);
		-webkit-backdrop-filter: blur(30px);
		border: 1px solid rgba(255, 255, 255, 0.15);
		border-top: 1px solid rgba(255, 255, 255, 0.3);
		border-radius: 24px;
		padding: 2rem;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		box-shadow:
			0 30px 60px rgba(0, 0, 0, 0.5),
			inset 0 1px 0 rgba(255, 255, 255, 0.1);
		pointer-events: auto;
	}
