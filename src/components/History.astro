---
import { sanityClient } from 'sanity:client';

const historyData = await sanityClient.fetch(`*[_type == "history"][0]`);
const milestones = historyData?.milestones?.map((m: any) => ({
	year: m.year,
	title: m.title,
	color: m.color || '#A213DA',
	description: m.description,
})) || [
	{
		year: '2004',
		title: 'Level Energy',
		color: '#A213DA',
		description:
			'Początek naszej drogi. Z pasją do innowacji i zrównoważonego rozwoju, założyliśmy fundamenty firmy, która miała zrewolucjonizować rynek energii odnawialnej w Polsce. Skupiliśmy się na dostarczaniu rozwiązań, które łączą ekologię z realnym zyskiem dla przedsiębiorstw.',
	},
	{
		year: '2006',
		title: 'Rekonstrukcja tamy wodnej we Włocławku',
		color: '#00D1FF',
		description:
			'Przełomowy projekt inżynieryjny, który udowodnił nasze kompetencje w realizacji skomplikowanych inwestycji hydroenergetycznych na skalę krajową. Wykorzystaliśmy innowacyjne systemy sterowania i optymalizacji przepływu, znacząco zwiększając wydajność obiektu.',
	},
	{
		year: '2012',
		title: 'Własna elektrownia wodna',
		color: '#2DD44F',
		description:
			'Uruchomienie własnego źródła energii było krokiem milowym w stronę niezależności i praktycznym potwierdzeniem efektywności naszych rozwiązań. Staliśmy się nie tylko dostawcą technologii, ale i aktywnym producentem czystej energii.',
	},
	{
		year: '2018',
		title: 'Stworzenie własnej metody sprzedażowej',
		color: '#FF9E00',
		description:
			'Wdrożyliśmy unikalny model doradztwa, oparty na głębokiej analizie potrzeb klienta i optymalizacji kosztów energetycznych, co stało się naszym znakiem rozpoznawczym. Nasza metoda "Value-Driven Sales" zrewolucjonizowała sposób, w jaki firmy podchodzą do inwestycji w OZE.',
	},
	{
		year: '2023',
		title: '760 milionów dofinansowania dla klientów',
		color: '#0047FF',
		description:
			'Rekordowy rok, w którym skutecznie pomogliśmy naszym partnerom pozyskać ogromne środki na modernizację infrastruktury. Ta suma realnie przełożyła się na dziesiątki zrealizowanych inwestycji i gigantyczne oszczędności w sektorze przemysłowym.',
	},
];
---

<section id="history" class="history-section">
	<div class="history-container">
		<h2 class="section-tag">HISTORIA</h2>

		<div class="timeline-accordion">
			{
				milestones.map((m: { year: string; title: string; color: string; description: string }, idx: number) => (
					<div
						class={`timeline-item ${idx === 1 ? 'is-active' : ''}`}
						role="button"
						tabindex="0"
						aria-expanded={idx === 1 ? 'true' : 'false'}
						aria-label={`Milestone year ${m.year}: ${m.title}`}
						style={`--accent-color: ${m.color}; --index: ${idx}`}
						data-year={m.year}>
						<div class="item-bg" />

						<div class="year-outline" aria-hidden="true">
							{m.year}
						</div>

						<div class="item-content">
							<div class="content-wrapper">
								<span class="year-mobile">{m.year}</span>
								<h3 class="milestone-title">{m.title}</h3>
								<div class="desc-container">
									<p class="milestone-desc">{m.description}</p>
								</div>

								<div class="level-up-wrapper">
									{idx < milestones.length - 1 ? (
										<button
											type="button"
											class="mini-level-up next-step"
											aria-label="Następny krok">
											Level Up{' '}
											<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
												<path d="M7 11l5-5 5 5M7 18l5-5 5 5" />
											</svg>
										</button>
									) : (
										<a href="#team" class="mini-level-up">
											Level Up{' '}
											<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
												<path d="M7 11l5-5 5 5M7 18l5-5 5 5" />
											</svg>
										</a>
									)}
								</div>
							</div>
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>

<script>
	const historyItems = document.querySelectorAll('.timeline-item') as NodeListOf<HTMLElement>;

	historyItems.forEach((item, index) => {
		const toggleItem = () => {
			if (item.classList.contains('is-active')) return;

			historyItems.forEach(i => {
				i.classList.remove('is-active');
				i.setAttribute('aria-expanded', 'false');
			});
			item.classList.add('is-active');
			item.setAttribute('aria-expanded', 'true');
		};

		item.addEventListener('click', toggleItem);

		item.addEventListener('keydown', e => {
			if (e.key === 'Enter' || e.key === ' ') {
				e.preventDefault();
				toggleItem();
			}
		});

		const nextBtn = item.querySelector('.next-step');
		if (nextBtn) {
			nextBtn.addEventListener('click', e => {
				e.stopPropagation();
				const nextIndex = index + 1;
				if (nextIndex < historyItems.length) {
					// Simulate click on the next item
					historyItems[nextIndex].click();
				}
			});
		}
	});
</script>

<style>
	.history-section {
		background: #0b111d;
		min-height: 100vh;
		position: relative;
		overflow: hidden;
		display: flex;
		flex-direction: column;
	}

	.history-container {
		display: flex;
		flex-direction: column;
		height: 100vh;
		width: 100%;
		padding-top: 2rem;
	}

	.section-tag {
		padding-left: 5%;
		font-size: 0.8rem;
		font-weight: 800;
		color: rgba(255, 255, 255, 0.4);
		letter-spacing: 0.2em;
		margin-bottom: 2rem;
	}

	.timeline-accordion {
		display: flex;
		flex: 1;
		width: 100%;
		overflow: hidden;
	}

	.timeline-item {
		position: relative;
		flex: 1;
		height: 100%;
		cursor: pointer;
		overflow: hidden;
		transition: flex 0.8s cubic-bezier(0.19, 1, 0.22, 1);
		border-left: 1px solid rgba(255, 255, 255, 0.05);
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
	}

	.timeline-item.is-active {
		flex: 5;
	}

	.item-bg {
		position: absolute;
		inset: 0;
		/* Default desktop: Bottom to top gradient */
		background: linear-gradient(to top, var(--accent-color) 0%, transparent 100%);
		opacity: 0;
		transform: scaleY(0);
		transform-origin: bottom;
		/* Much slower, more deliberate transition for luxury feel */
		transition:
			opacity 1.2s cubic-bezier(0.19, 1, 0.22, 1),
			transform 1.5s cubic-bezier(0.19, 1, 0.22, 1);
		z-index: 1;
	}

	.timeline-item:hover .item-bg {
		opacity: 0.3;
		transform: scaleY(1);
	}

	.timeline-item.is-active .item-bg {
		opacity: 1;
		transform: scaleY(1);
		transition:
			opacity 0.8s cubic-bezier(0.19, 1, 0.22, 1),
			transform 1.2s cubic-bezier(0.19, 1, 0.22, 1);
	}

	/* Large Year Outline - Centered and Contained */
	.year-outline {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%) rotate(-90deg);
		/* Smaller font size to ensure it never touches edges of its column */
		font-size: clamp(6rem, 12vw, 12rem);
		font-family: 'Outfit', sans-serif; /* Geometric font for cleaner outlines */
		font-weight: 900;
		color: rgba(255, 255, 255, 0.03);
		-webkit-text-stroke: 1.5px rgba(255, 255, 255, 0.25);
		letter-spacing: 0.15em;
		pointer-events: none;
		white-space: nowrap;
		z-index: 2;
		transition:
			opacity 1s cubic-bezier(0.19, 1, 0.22, 1),
			top 1s cubic-bezier(0.19, 1, 0.22, 1),
			transform 1s cubic-bezier(0.19, 1, 0.22, 1);
		/* Force equal width for all numbers so every year has the same length */
		font-variant-numeric: tabular-nums;
		font-feature-settings: 'tnum';
	}

	.timeline-item:hover .year-outline {
		-webkit-text-stroke: 1.5px rgba(255, 255, 255, 0.4);
		opacity: 0.8;
	}

	.timeline-item.is-active .year-outline {
		opacity: 0.1;
		top: 2%; /* Moved much higher */
		left: 50%;
		transform: translate(-50%, 0) rotate(0deg) scale(2.5);
		-webkit-text-stroke: 2px white;
		color: transparent;
		letter-spacing: 0.05em;
	}

	.item-content {
		position: relative;
		z-index: 10;
		padding: 2rem 0.5rem 4rem 0.5rem;
		width: 100%;
		height: 100%;
		display: flex;
		align-items: flex-end;
		justify-content: center;
		pointer-events: none;
	}

	.timeline-item.is-active .item-content {
		pointer-events: auto;
		padding: 2rem 4rem 4rem 4rem; /* Restore padding when active */
	}

	.year-mobile {
		display: none;
	}

	.content-wrapper {
		display: flex;
		flex-direction: column;
		align-items: center; /* Center text visually in the narrow col */
		text-align: center;
		width: 100%;
	}

	.milestone-title {
		font-size: clamp(0.85rem, 0.9vw, 1.2rem); /* Slightly smaller for better fit */
		font-weight: 800;
		color: white;
		line-height: 1.3;
		margin-bottom: 0px;
		width: 100%;
		max-width: none; /* Allow full width */
		transition: transform 0.8s cubic-bezier(0.19, 1, 0.22, 1);
		transform-origin: bottom center;
		text-transform: none;
		transform: translateY(0);
		hyphens: auto; /* Optional: help with very long words if needed */
	}

	.timeline-item.is-active .milestone-title {
		max-width: 700px;
		margin-bottom: 1.5rem;
		transform: scale(2.2);
		margin-top: auto; /* Push to bottom if needed */
	}

	/* Description reveal logic */
	.desc-container {
		display: grid;
		grid-template-rows: 0fr;
		transition: grid-template-rows 0.8s cubic-bezier(0.19, 1, 0.22, 1);
		width: 100%;
		max-width: 600px;
	}

	.timeline-item.is-active .desc-container {
		grid-template-rows: 1fr;
	}

	.milestone-desc {
		font-size: 1.1rem;
		color: rgba(255, 255, 255, 0.9);
		line-height: 1.7;
		max-width: 600px;
		overflow: hidden;
		opacity: 0;
		transform: translateY(20px);
		transition:
			opacity 0.6s ease,
			transform 0.6s cubic-bezier(0.19, 1, 0.22, 1);
	}

	.timeline-item.is-active .milestone-desc {
		opacity: 1;
		transform: translateY(0);
		transition-delay: 0.3s;
	}

	/* Mini Level Up Button Animation */
	.level-up-wrapper {
		margin-top: 3rem;
		opacity: 0;
		transform: translateY(20px);
		transition:
			opacity 0.6s cubic-bezier(0.19, 1, 0.22, 1),
			transform 0.6s cubic-bezier(0.19, 1, 0.22, 1);
		pointer-events: none;
	}

	.timeline-item.is-active .level-up-wrapper {
		opacity: 1;
		transform: translateY(0);
		transition-delay: 0.5s;
		pointer-events: auto;
	}

	.mini-level-up {
		display: inline-flex;
		align-items: center;
		gap: 0.8rem;
		padding: 0.8rem 1.8rem;
		border-radius: 9999px;
		border: 1px solid white;
		background: transparent;
		color: white;
		text-decoration: none;
		text-transform: uppercase;
		font-weight: 800;
		font-size: 0.8rem;
		letter-spacing: 0.1em;
		font-family: inherit;
		cursor: pointer;
		transition:
			background 0.3s ease,
			color 0.3s ease;
	}

	.mini-level-up:hover {
		background: white;
		color: black;
	}

	.mini-level-up svg {
		width: 1rem;
		height: 1rem;
	}

	/* Mobile Responsive Styles */
	@media (max-width: 1023px) {
		.history-container {
			height: auto;
			padding-bottom: 5rem;
		}

		.timeline-accordion {
			flex-direction: column;
		}

		.timeline-item {
			min-height: 100px;
			flex: none;
			border-left: none;
			border-top: 1px solid rgba(255, 255, 255, 0.05);
		}

		.item-bg {
			/* Mobile: Left to right gradient and horizontal fill */
			background: linear-gradient(to right, var(--accent-color) 0%, transparent 100%);
			transform: scaleX(0);
			transform-origin: left;
		}

		.timeline-item:hover .item-bg,
		.timeline-item.is-active .item-bg {
			transform: scaleX(1);
		}

		.timeline-item.is-active {
			min-height: 450px;
		}

		.year-outline {
			font-size: 12vh;
			top: 50%;
			left: 50%;
			transform: translate(-50%, -50%) rotate(0deg);
			-webkit-text-stroke: 1px rgba(255, 255, 255, 0.2);
			transition: all 0.8s cubic-bezier(0.19, 1, 0.22, 1);
		}

		.timeline-item.is-active .year-outline {
			font-size: 18vh;
			left: 50%;
			top: 5%;
			transform: translate(-50%, 0) rotate(0deg);
			opacity: 0.15;
		}

		.year-mobile {
			display: block;
			font-size: 1.1rem;
			font-weight: 900;
			opacity: 0.5;
			margin-bottom: 0.5rem;
			color: var(--accent-color);
		}

		.item-content {
			padding: 2rem 1.5rem;
		}

		.milestone-title {
			font-size: 1.5rem;
			margin-bottom: 1rem;
			transform: scale(1) !important; /* Force reset desktop scale */
			line-height: 1.2;
		}

		.timeline-item.is-active .milestone-title {
			transform: scale(1) !important;
			margin-bottom: 1.5rem;
			font-size: 1.8rem;
		}
	}
</style>
