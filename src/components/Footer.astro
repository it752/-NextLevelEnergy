</style>

<script>
	const nlForm = document.getElementById('footer-newsletter-form') as HTMLFormElement;
	const nlBtn = document.getElementById('nl-submit-btn') as HTMLButtonElement | null;
	const nlSuccess = document.getElementById('nl-success-msg');
	const nlError = document.getElementById('nl-error-msg');

	if (nlForm && nlBtn) {
		nlForm.addEventListener('submit', async e => {
			e.preventDefault();

			const originalText = nlBtn.innerHTML;
			nlBtn.innerHTML =
				'Zapisywanie... <svg viewBox="0 0 24 24" fill="none" class="animate-spin inline ml-2 w-4 h-4" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M12 2v4"></path></svg>';
			nlBtn.style.opacity = '0.7';
			nlBtn.disabled = true;

			if (nlSuccess) nlSuccess.classList.add('hidden');
			if (nlError) nlError.classList.add('hidden');

			const formData = new FormData(nlForm);
			const payload = {
				email: formData.get('email'),
			};

			try {
				const response = await fetch('https://hook.eu1.make.com/b9ejxp876syewyp2ggjwm9l3d6v7qzpt', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify(payload),
				});

				if (!response.ok) throw new Error('Network error');

				if (nlSuccess) nlSuccess.classList.remove('hidden');
				nlForm.reset();
			} catch (err) {
				console.error('Newsletter error:', err);
				if (nlError) nlError.classList.remove('hidden');
			} finally {
				nlBtn.innerHTML = originalText;
				nlBtn.style.opacity = '1';
				nlBtn.disabled = false;
			}
		});
	}
	// Contact Form logic
	const contactForm = document.getElementById('contact-form') as HTMLFormElement;
	const contactBtn = document.getElementById('contact-submit-btn') as HTMLButtonElement | null;
	const contactSuccess = document.getElementById('contact-success-msg');
	const contactError = document.getElementById('contact-error-msg');

	if (contactForm && contactBtn) {
		contactForm.addEventListener('submit', async e => {
			e.preventDefault();

			const originalText = contactBtn.innerHTML;
			contactBtn.innerHTML =
				'<span class="btn-icon"><svg viewBox="0 0 24 24" fill="none" class="animate-spin w-4 h-4" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M12 2v4"></path></svg></span> Wysyłanie...';
			contactBtn.style.opacity = '0.7';
			contactBtn.disabled = true;

			if (contactSuccess) contactSuccess.classList.add('hidden');
			if (contactError) contactError.classList.add('hidden');

			const formData = new FormData(contactForm);

			try {
				const response = await fetch('/api/contact', {
					method: 'POST',
					body: formData,
				});

				if (!response.ok) throw new Error('Network error');

				if (contactSuccess) contactSuccess.classList.remove('hidden');
				contactForm.reset();
			} catch (err) {
				console.error('Contact error:', err);
				if (contactError) contactError.classList.remove('hidden');
			} finally {
				contactBtn.innerHTML = originalText;
				contactBtn.style.opacity = '1';
				contactBtn.disabled = false;
			}
		});
	}
</script>
