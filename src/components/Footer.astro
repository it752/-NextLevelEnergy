---
// Footer.astro
import { Image } from 'astro:assets';
import bgFooter from '../assets/footer/bg-footer.png';
import { GlowingEffect } from './ui/glowing-effect.tsx';
---

<section id="contact" class="footer-next-container">
	<!-- Dashboard Container -->
	<div class="footer-dashboard">
		<!-- Background Texture & Glows -->
		<div class="dashboard-bg">
			<Image src={bgFooter} alt="" class="bg-texture" quality={70} format="webp" />
			<div class="glow-sphere sphere-1"></div>
			<div class="glow-sphere sphere-2"></div>
			{/* <div class="noise-overlay"></div> Removed for performance */}
		</div>

		<div class="dashboard-content">
			<!-- Header / Title Area -->
			<div class="footer-header">
				<div class="header-eyebrow">
					<svg class="nf-bolt" viewBox="0 0 24 24" fill="currentColor">
						<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
					</svg>
					<span>NEXT LEVEL ENERGY</span>
				</div>
				<h2 class="main-heading">
					<span class="heading-line line-1">Inicjuj</span>
					<span class="heading-line line-2">
						<span class="gradient-text">Połączenie</span>
						<svg
							class="sparkle-icon"
							width="48"
							height="48"
							viewBox="0 0 24 24"
							fill="none"
							xmlns="http://www.w3.org/2000/svg">
							<path
								d="M12 2L14.4 9.6L22 12L14.4 14.4L12 22L9.6 14.4L2 12L9.6 9.6L12 2Z"
								fill="#A213DA"
								filter="drop-shadow(0 0 10px #A213DA)"></path>
						</svg>
					</span>
				</h2>
				<p class="dash-desc">
					Gotowy na optymalizację energetyczną? Skontaktuj się z nami lub dołącz do globalnej sieci
					informacyjnej Next Level Energy.
				</p>
			</div>

			<!-- Two Column Action Area -->
			<div class="action-grid">
				<!-- Column 1: Contact Form Glass Card -->
				<div class="glass-card contact-card">
					<!-- Glow effect container sits perfectly on the border -->
					<div class="glowing-effect-container absolute inset-0 pointer-events-none">
						<GlowingEffect
							spread={40}
							glow={true}
							disabled={false}
							proximity={64}
							inactiveZone={0.01}
							borderWidth={3}
							borderRadius={24}
							client:idle
						/>
					</div>
					<!-- Background Glass Layer that correctly clips internal overflow without clipping the outside glow -->
					<div class="glass-bg-layer absolute inset-0 rounded-[24px] pointer-events-none"></div>

					<h3 class="card-title relative z-10">Wyślij zapytanie</h3>
					<form class="contact-form relative z-10" id="contact-form">
						<div class="form-row">
							<div class="input-group">
								<input
									type="text"
									id="contact-name"
									name="name"
									placeholder="Imię i nazwisko"
									required
								/>
							</div>
							<div class="input-group">
								<input
									type="email"
									id="contact-email"
									name="email"
									placeholder="Adres e-mail"
									required
								/>
							</div>
						</div>
						<div class="input-group">
							<input
								type="tel"
								id="contact-phone"
								name="phone"
								placeholder="Numer telefonu (opcjonalnie)"
							/>
						</div>
						<div class="input-group">
							<textarea id="contact-msg" name="message" rows="3" placeholder="Treść wiadomości" required
							></textarea>
						</div>

						<label class="nl-checkbox">
							<input type="checkbox" required />
							<span class="nl-mark"></span>
							<span class="nl-text"
								>Akceptuję politykę prywatności i wyrażam zgodę na przetwarzanie danych.</span
							>
						</label>

						<p id="contact-success-msg" class="hidden text-green-400 text-sm mt-2">
							Wiadomość została wysłana pomyślnie!
						</p>
						<p id="contact-error-msg" class="hidden text-red-400 text-sm mt-2">
							Wystąpił błąd podczas wysyłania. Spróbuj ponownie.
						</p>

						<button type="submit" id="contact-submit-btn" class="primary-btn-neon w-full">
							<span class="btn-icon">
								<svg
									viewBox="0 0 24 24"
									width="16"
									height="16"
									fill="none"
									stroke="currentColor"
									stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
								>
							</span>
							Transmituj Wiadomość
						</button>
					</form>
				</div>

				<!-- Column 2: Newsletter & Info -->
				<div class="info-column">
					<div class="glass-card newsletter-card">
						<div class="glowing-effect-container absolute inset-0 pointer-events-none">
							<GlowingEffect
								spread={40}
								glow={true}
								disabled={false}
								proximity={64}
								inactiveZone={0.01}
								borderWidth={3}
								borderRadius={24}
								client:idle
							/>
						</div>
						<div class="glass-bg-layer absolute inset-0 rounded-[24px] pointer-events-none"></div>

						<div class="card-header-small relative z-10">
							<span class="card-eyebrow">SYSTEM UPDATE</span>
						</div>
						<h3 class="card-title relative z-10">Newsletter</h3>
						<p class="card-text relative z-10">
							Odbieraj powiadomienia o nowych technologiach i rozwiązaniach OZE.
						</p>

						<form class="newsletter-form relative z-10" id="footer-newsletter-form">
							<div class="input-group">
								<input
									type="email"
									id="newsletter-email"
									name="email"
									placeholder="Twój e-mail"
									required
								/>
							</div>
							<label class="nl-checkbox">
								<input type="checkbox" required />
								<span class="nl-mark"></span>
								<span class="nl-text">Zgadzam się na otrzymywanie informacji handlowych.</span>
							</label>
							<p id="nl-success-msg" class="hidden text-green-400 text-sm mt-2">
								Dziękujemy za zapis do newslettera!
							</p>
							<p id="nl-error-msg" class="hidden text-red-400 text-sm mt-2">
								Wystąpił błąd. Spróbuj ponownie.
							</p>
							<button type="submit" id="nl-submit-btn" class="outline-btn-neon w-full"
								>Zasubskrybuj kanał</button
							>
						</form>
					</div>

					<div class="glass-card details-card">
						<div class="glowing-effect-container absolute inset-0 pointer-events-none">
							<GlowingEffect
								spread={40}
								glow={true}
								disabled={false}
								proximity={64}
								inactiveZone={0.01}
								borderWidth={3}
								borderRadius={24}
								client:idle
							/>
						</div>
						<div class="glass-bg-layer absolute inset-0 rounded-[24px] pointer-events-none"></div>

						<h3 class="card-title relative z-10">Nasze Biura</h3>
						<div class="company-address relative z-10 flex flex-col gap-4">
							<div class="address-item">
								<span class="block text-[#a213da] font-bold text-xs uppercase mb-1">Poznań</span>
								ul. Kopanina 34<br />
								60-105 Poznań
							</div>
							<div class="address-item">
								<span class="block text-[#a213da] font-bold text-xs uppercase mb-1">Gdańsk</span>
								ul. Żeleńskiego 50A/3<br />
								80-285 Gdańsk
							</div>
							<div class="contact-links pt-2">
								<a href="mailto:biuro@nextlevelenergy.pl" class="block">biuro@nextlevelenergy.pl</a>
								<a href="tel:+48729979179" class="block">+48 729 979 179</a>
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- Bottom Footer Bar -->
			<div class="footer-bottom-bar">
				<div class="social-links">
					<a href="#" aria-label="Instagram">IG</a>
					<a href="#" aria-label="Facebook">FB</a>
					<a href="#" aria-label="X (Twitter)">X</a>
					<a href="#" aria-label="LinkedIn">IN</a>
				</div>
				<div class="bottom-legal">
					<a href="/regulamin">Regulamin</a>
					<span class="dot">•</span>
					<a href="/rodo">RODO</a>
					<span class="dot">•</span>
					<a href="/polityka-prywatnosci">Polityka prywatności</a>
					<span class="dot">•</span>
					<button type="button" data-cc="show-preferencesModal" class="cookie-link">Cookies</button>
				</div>
				<div class="copyright">
					© {new Date().getFullYear()} Next Level Energy. <span class="creator"
						>Powered by <a href="https://pawlukstudio.pl/pl" target="_blank" rel="noopener noreferrer"
							>Pawluk Studio</a
						></span
					>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.footer-next-container {
		width: 100%;
		/* min-height: 100vh; -- Removed to allow better lazy rendering */
		background-color: #020202; /* Very dark outside background matching Hero */
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 4rem 2rem; /* Replaced padding as requested */
		overflow: hidden;
		position: relative;
	}

	.footer-dashboard {
		width: 100%;
		height: 100%;
		min-height: 85vh;
		max-width: 1440px; /* Nieco węższy od hero żeby był skupiony wokół formularza */
		margin: 0 auto;
		border-radius: 40px;
		border: 1px solid rgba(255, 255, 255, 0.1);
		background: #0b111d;
		/* overflow: hidden removed to stop compositing limits on children */
		position: relative;
		contain: layout style paint; /* Replaced overflow hidden */
		isolation: isolate; /* Creates a new stacking context for shadow efficiency */
		display: flex;
		flex-direction: column;
	}

	.footer-dashboard::after {
		content: '';
		position: absolute;
		inset: 0;
		border-radius: inherit;
		background: transparent;
		box-shadow: 0 40px 100px rgba(0, 0, 0, 0.9);
		pointer-events: none;
		z-index: -1;
	}

	/* Dashboard Background Layer */
	.dashboard-bg {
		position: absolute;
		inset: 0;
		z-index: 0;
		pointer-events: none;
		border-radius: 40px; /* Moved from parent */
		overflow: hidden; /* Only clip the background layer itself */
	}
	.bg-texture {
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0.15;
		/* Disabled color-dodge as it destroys scroll performance */
		/* mix-blend-mode: color-dodge; */
		transform: translateZ(0);
	}
	.glow-sphere {
		position: absolute;
		border-radius: 50%;
		/* Removed filter: blur(100px) as radial-gradient provides the softness inherently, avoiding massive GPU cost */
		opacity: 0.4;
	}
	.sphere-1 {
		width: 800px;
		height: 800px;
		background: radial-gradient(circle, rgba(162, 19, 218, 0.7) 0%, rgba(162, 19, 218, 0) 70%);
		right: 0%;
		top: 10%;
		transform: translate(30%, -30%);
	}
	.sphere-2 {
		width: 600px;
		height: 600px;
		background: radial-gradient(circle, rgba(162, 19, 218, 0.4) 0%, rgba(162, 19, 218, 0) 70%);
		left: -10%;
		bottom: -10%;
	}
	.noise-overlay {
		/* removed noise filter due to extreme performance drop during scrolling */
	}

	/* Main Content Wrapper */
	.dashboard-content {
		position: relative;
		z-index: 10;
		padding: 4rem 6rem 2rem;
		display: flex;
		flex-direction: column;
		flex: 1;
		color: white;
	}

	/* Header Typography */
	.footer-header {
		text-align: center;
		margin-bottom: 4rem;
		display: flex;
		flex-direction: column;
		align-items: center;
	}
	.header-eyebrow {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.75rem;
		letter-spacing: 0.2em;
		color: rgba(255, 255, 255, 0.5);
		text-transform: uppercase;
		margin-bottom: 1.5rem;
	}
	.nf-bolt {
		width: 16px;
		height: 16px;
		color: #a213da;
	}

	.main-heading {
		font-size: clamp(3rem, 5vw, 4.5rem);
		font-weight: 850;
		line-height: 1.05;
		letter-spacing: -0.04em;
		display: flex;
		flex-direction: column;
		align-items: center;
		margin-bottom: 1.5rem;
	}
	.heading-line {
		display: block;
	}
	.heading-line.line-2 {
		display: flex;
		align-items: center;
		flex-wrap: nowrap;
	}
	.gradient-text {
		color: #a213da;
		display: inline-block;
		padding-right: 15px;
	}
	.sparkle-icon {
		flex-shrink: 0;
		display: block;
		margin-top: -10px;
		animation: spin-slow 8s infinite linear;
		will-change: transform;
	}
	@keyframes spin-slow {
		100% {
			transform: rotate(360deg);
		}
	}

	.dash-desc {
		font-size: 1.1rem;
		color: rgba(255, 255, 255, 0.7);
		line-height: 1.6;
		max-width: 600px;
		font-weight: 400;
	}

	/* Grid Layout */
	.action-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2rem;
		flex: 1;
		align-items: stretch;
	}

	.info-column {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	/* Glassmorphism Cards Container Layer */
	.glass-card {
		position: relative;
		/* overflow: hidden removed to let glowing borders bleed out */
		border-radius: 24px;
		padding: 2.5rem;
	}

	/* Inner background layer for glass effect & shadows */
	.glass-bg-layer {
		background: rgba(11, 17, 29, 0.85); /* Solidified for performance */
		/* backdrop-filter: blur(12px) removed to stop massive layout/rendering GPU hits */
		transform: translateZ(0);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-top: 1px solid rgba(255, 255, 255, 0.2);
		border-radius: 24px;
		overflow: hidden; /* Only clip the background contents */
		z-index: 1;
	}

	.glass-bg-layer::before {
		content: '';
		position: absolute;
		inset: 0;
		border-radius: inherit;
		box-shadow:
			0 30px 60px rgba(0, 0, 0, 0.3),
			inset 0 1px 0 rgba(255, 255, 255, 0.05);
		pointer-events: none;
	}

	/* The actual glowing component sits behind/around the content but effectively on top of bg */
	.glowing-effect-container {
		z-index: 2; /* Needs to be above the glass background layer so border shows correctly */
	}

	/* Ensure all card actual content stays on top of both the background and the glow */
	.glass-card > *:not(.glowing-effect-container):not(.glass-bg-layer) {
		position: relative;
		z-index: 10;
	}

	.contact-card {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.card-title {
		font-size: 1.5rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		margin-bottom: 0.5rem;
	}

	.card-text {
		font-size: 0.9rem;
		color: rgba(255, 255, 255, 0.6);
		line-height: 1.6;
		margin-bottom: 1.5rem;
	}

	.card-eyebrow {
		font-size: 0.65rem;
		color: rgba(255, 255, 255, 0.5);
		letter-spacing: 0.2em;
		text-transform: uppercase;
		display: block;
		margin-bottom: 1rem;
	}

	/* Forms inside cards */
	form {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		width: 100%;
	}

	.form-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.25rem;
	}

	.input-group input,
	.input-group textarea {
		width: 100%;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 12px;
		padding: 1rem 1.25rem;
		color: white;
		font-size: 0.95rem;
		font-family: inherit;
		transition:
			border-color 0.3s ease,
			background 0.3s ease,
			box-shadow 0.3s ease;
		resize: none;
	}

	.input-group input::placeholder,
	.input-group textarea::placeholder {
		color: rgba(255, 255, 255, 0.3);
	}

	.input-group input:focus,
	.input-group textarea:focus {
		outline: none;
		border-color: #a213da;
		background: rgba(255, 255, 255, 0.05);
		box-shadow: 0 0 0 4px rgba(162, 19, 218, 0.1);
	}

	/* Checkboxes */
	.nl-checkbox {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
		cursor: pointer;
		margin-top: 0.5rem;
	}
	.nl-checkbox input {
		display: none;
	}
	.nl-mark {
		width: 18px;
		height: 18px;
		border: 1px solid rgba(255, 255, 255, 0.3);
		border-radius: 4px;
		margin-top: 2px;
		position: relative;
		flex-shrink: 0;
		transition: all 0.2s;
	}
	.nl-checkbox:hover .nl-mark {
		border-color: rgba(255, 255, 255, 0.6);
	}
	.nl-mark::after {
		content: '';
		position: absolute;
		display: none;
		left: 6px;
		top: 2px;
		width: 4px;
		height: 8px;
		border: solid white;
		border-width: 0 2px 2px 0;
		transform: rotate(45deg);
	}
	.nl-checkbox input:checked ~ .nl-mark {
		background: #a213da;
		border-color: #a213da;
	}
	.nl-checkbox input:checked ~ .nl-mark::after {
		display: block;
	}
	.nl-text {
		color: rgba(255, 255, 255, 0.4);
		font-size: 0.75rem;
		line-height: 1.5;
	}

	/* Buttons styling matched to Hero */
	.primary-btn-neon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 1.25rem;
		padding: 0.5rem 2rem 0.5rem 0.5rem;
		border-radius: 99px;
		background: #a213da;
		color: white;
		font-weight: 600;
		text-transform: uppercase;
		text-decoration: none;
		letter-spacing: 0.05em;
		font-size: 0.85rem;
		border: none;
		cursor: pointer;
		box-shadow: 0 10px 30px rgba(162, 19, 218, 0.4);
		transition:
			transform 0.4s cubic-bezier(0.19, 1, 0.22, 1),
			box-shadow 0.4s cubic-bezier(0.19, 1, 0.22, 1);
		margin-top: 1rem;
	}
	.primary-btn-neon:hover {
		transform: translateY(-3px) scale(1.02);
		box-shadow: 0 15px 40px rgba(162, 19, 218, 0.5);
	}
	.primary-btn-neon.w-full {
		width: 100%;
		padding-right: 1.5rem;
		justify-content: flex-start;
	}

	.btn-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		background: rgba(255, 255, 255, 0.2);
		border-radius: 50%;
		transform: translateZ(0);
	}

	.outline-btn-neon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 1rem 2rem;
		border-radius: 99px;
		border: 1px solid rgba(255, 255, 255, 0.2);
		background: transparent;
		color: white;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		font-size: 0.85rem;
		cursor: pointer;
		transition:
			background 0.3s ease,
			border-color 0.3s ease;
		margin-top: 1rem;
	}
	.outline-btn-neon:hover {
		background: rgba(255, 255, 255, 0.1);
		border-color: white;
	}
	.outline-btn-neon.w-full {
		width: 100%;
	}

	/* Company Address Column */
	.details-card {
		flex: 1;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.company-address {
		font-size: 1rem;
		font-weight: 500;
		line-height: 1.8;
		color: rgba(255, 255, 255, 0.8);
	}
	.company-address a {
		color: white;
		text-decoration: none;
		transition: color 0.3s;
	}
	.company-address a:hover {
		color: #a213da;
	}

	/* Bottom Footer Bar */
	.footer-bottom-bar {
		margin-top: 5rem;
		padding-top: 2rem;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 1.5rem;
	}

	.social-links {
		display: flex;
		gap: 1.5rem;
	}
	.social-links a {
		color: rgba(255, 255, 255, 0.6);
		text-decoration: none;
		font-size: 0.85rem;
		font-weight: 600;
		transition: color 0.3s;
	}
	.social-links a:hover {
		color: white;
	}

	.bottom-legal {
		display: flex;
		align-items: center;
		gap: 1rem;
		font-size: 0.8rem;
		color: rgba(255, 255, 255, 0.5);
	}
	.bottom-legal a,
	.cookie-link {
		color: inherit;
		text-decoration: none;
		transition: color 0.3s;
		background: none;
		border: none;
		font-family: inherit;
		font-size: inherit;
		cursor: pointer;
		padding: 0;
	}
	.bottom-legal a:hover,
	.cookie-link:hover {
		color: white;
	}
	.dot {
		opacity: 0.3;
	}

	.copyright {
		font-size: 0.8rem;
		color: rgba(255, 255, 255, 0.4);
	}
	.creator a {
		color: rgba(255, 255, 255, 0.7);
		text-decoration: none;
	}
	.creator a:hover {
		color: white;
	}

	/* Responsive */
	@media (max-width: 1024px) {
