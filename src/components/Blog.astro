---
import { Image } from 'astro:assets';
import blog1 from '../assets/blog/blog-1.png';
import blog2 from '../assets/blog/blog-2.png';
import blog3 from '../assets/blog/blog-3.png';
import { GlowingEffect } from './ui/glowing-effect.tsx';

const posts = [
	{
		id: 1,
		title: 'Integracja zespołu w polskich górach',
		date: '12.02.2025',
		excerpt: 'Weekend pełen wyzwań i wspólnej zabawy.',
		fullText:
			'W naszej firmie wierzymy, że najlepsze pomysły rodzą się z dala od biurek. Nasz ostatni wyjazd integracyjny do Zakopanego to nie tylko kilometry pokonane na szlakach, ale też dziesiątki godzin rozmów i wspólnych gier, które zbliżyły nas do siebie. Po wymagającym sezonie projektowym taki odpoczynek był nam wszystkim potrzebny. W górach nauczyliśmy się ufać sobie nawzajem i jeszcze sprawniej rozwiązywać problemy jako zespół. Zobaczcie sami, jak Level Up ładuje baterie przed kolejnymi wyzwaniami w branży OZE!',
		image: blog1,
	},
	{
		id: 2,
		title: 'Akademia Liderów – pierwsza edycja',
		date: '08.02.2025',
		excerpt: 'Inwestujemy w rozwój kompetencji miękkich.',
		fullText:
			'Rozwój techniczny to u nas podstawa, ale wiemy, że efektywne zarządzanie projektami i relacjami wymaga czegoś więcej. Z dumą ogłaszamy zakończenie pierwszej edycji naszej "Akademii Liderów" – trzymiesięcznego cyklu warsztatów z asertywności, rozwiązywania konfliktów i motywowania zespołu. Program zgromadził kilkunastu najbardziej zaangażowanych pracowników, którzy pod okiem doświadczonych mentorów doskonalili swoje predyspozycje do objęcia w przyszłości ważnych ról w strukturach naszej filmy.',
		image: blog2,
	},
	{
		id: 3,
		title: 'Nasze nowe biuro – więcej niż miejsce pracy',
		date: '01.02.2025',
		excerpt: 'Przestrzeń zaprojektowana z myślą o ludziach.',
		fullText:
			'Kolejny krok przed nami! Otworzyliśmy nowoczesną siedzibę, która została zaprojektowana specjalnie dla naszego rosnącego zespołu inżynierów i handlowców. Stworzyliśmy przestrzeń, która promuje kreatywność – znajdziecie tu zarówno ciche strefy do pracy w skupieniu, jak i duże obszary wspólne sprzyjające swobodnej wymianie pomysłów przy kawie. Ale największym hitem biura jest zdecydowanie nasza sala relaksu z piłkarzykami i konsolą. Nowe biuro to obietnica lepszych warunków dla każdego z naszych pracowników.',
		image: blog3,
	},
	{
		id: 4,
		title: 'Mistrzostwa firmy w kartingu',
		date: '25.01.2025',
		excerpt: 'Sportowa rywalizacja poza godzinami pracy.',
		fullText:
			'W ostatni weekend nasz zespół postanowił zmierzyć się w nieco innej domenie niż dotychczas – zorganizowaliśmy firmowe mistrzostwa w wyścigach gokartów! Po emocjonujących eliminacjach i niesamowicie zaciętym finale wyłoniliśmy zwycięzcę z działu technicznego. Jednak tego dnia nie liczyły się tylko czasy okrążeń. Liczyła się zdrowa, przyjazna sportowa rywalizacja, zbijanie "piątek" i niesamowita atmosfera. Tego typu spotkania wspaniale odstresowują nas po trudach codziennej, intensywnej pracy.',
		image: blog1,
	},
	{
		id: 5,
		title: 'Targi technologii OZE – byliśmy tam!',
		date: '15.01.2025',
		excerpt: 'Nasi inżynierowie zdobywają nową wiedzę.',
		fullText:
			'Branża Odnawialnych Źródeł Energii pędzi do przodu z niesamowitą prędkością, dlatego nasi specjaliści po prostu muszą być na bieżąco. Grupa inżynierów i projektantów z naszej firmy wzięła udział w największych branżowych targach we Frankfurcie. Zdobyliśmy tam masę nowej wiedzy o pompach ciepła nowej generacji i zaawansowanych systemach zarządzania energią (BMS). Ta cenna wiedza już niedługo zostanie przekuta w realne szkolenia wewnętrzne, podnosząc kompetencje wszystkich pracowników.',
		image: blog2,
	},
	{
		id: 6,
		title: 'Owocowe czwartki? Śniadania!',
		date: '05.01.2025',
		excerpt: 'Rozmowy przy stole w drodze do pracy.',
		fullText:
			'W zeszłym miesiącu zrobiliśmy mały audyt naszych firmowych benefitów. Odkryliśmy, że zamiast standardowych rozwiązań, nasz zespół znacznie bardziej ceni wspólnie spędzany czas! Dlatego wprowadziliśmy tradycję piątkowych "Wielkich Śniadań". Dział po departamencie - co tydzień ktoś inny przejmuje kuchenne stery i przygotowuje autorskie posiłki dla całego biura. Od pancaków po tradycyjne jajecznice. Taka przerwa sprzyja wzmacnianiu relacji i lepszej współpracy w nadchodzącym tygodniu.',
		image: blog3,
	},
];
---

<section id="idea" class="blog-section selection:bg-[#a213da] selection:text-white">
	<!-- Ambient Background Glows -->
	<div class="ambient-glow glow-primary"></div>
	<div class="ambient-glow glow-secondary"></div>
	<div class="edge-fade edge-fade-top"></div>
	<div class="edge-fade edge-fade-bottom"></div>

	<div class="bento-container">
		<!-- Header -->
		<div class="bento-header">
			<div class="bento-badge">
				<span class="pulse-dot"></span>
				<span class="badge-text">Employer Branding</span>
			</div>
			<h2 class="bento-heading">
				Życie firmy <span class="bg-clip-text text-transparent bg-gradient-to-r from-[#a213da] to-[#c026d3]"
					>od kuchni</span
				>,<br />
				czyli blog naszego zespołu.
			</h2>
			<p class="bento-subheading">
				Rozwijamy technologie przyszłości, ale to ludzie są naszym największym zasobem. Przeczytaj najnowsze
				wpisy o naszych wyjazdach, szkoleniach i codziennym życiu biurowym Level Up.
			</p>
		</div>

		<!-- Bento Grid -->
		<div class="bento-grid">
			{
				posts.map((post, i) => {
					let visibilityClasses = '';
					if (i >= 3 && i < 6) {
						// Hide only on mobile (<768px), normally it is block but bento grids need nothing special
						visibilityClasses = 'max-md:hidden max-md:opacity-0';
					} else if (i >= 6) {
						visibilityClasses = 'hidden opacity-0';
					}

					return (
						<div
							class={`bento-card group item-${i % 6} post-card ${visibilityClasses}`}
							data-id={post.id}
							data-title={post.title}
							data-date={post.date}
							data-excerpt={post.excerpt}
							data-text={post.fullText}
							data-img={post.image.src}>
							<div
								class="glowing-effect-container absolute inset-0 pointer-events-none"
								style="border-radius: 24px; z-index: 5;">
								<GlowingEffect
									spread={40}
									glow={true}
									disabled={false}
									proximity={64}
									inactiveZone={0.01}
									borderWidth={3}
									borderRadius={24}
									client:load
								/>
							</div>
							<div class="bento-inner">
								<div class="bento-image-wrapper">
									<Image src={post.image} alt={post.title} class="bento-img" />
									<div class="bento-overlay" />
								</div>
								<div class="bento-content">
									<div class="bento-meta">
										<span class="bento-date">{post.date}</span>
										<div class="bento-arrow">
											<svg
												viewBox="0 0 24 24"
												width="16"
												height="16"
												stroke="currentColor"
												stroke-width="2"
												fill="none"
												class="bento-arrow-icon">
												<path d="M5 12h14M12 5l7 7-7 7" />
											</svg>
										</div>
									</div>
									<h3 class="bento-title">{post.title}</h3>
									<p class="bento-excerpt">{post.excerpt}</p>
								</div>
							</div>
						</div>
					);
				})
			}
		</div>

		<!-- Load More Button -->
		{
			posts.length > 3 && (
				<div
					id="load-more-wrapper"
					class={`flex justify-center mt-12 relative z-50 ${posts.length <= 6 ? 'md:hidden' : ''}`}>
					<button
						id="load-more-btn"
						class="group relative px-6 py-3 rounded-full bg-white/5 border border-white/20 text-white font-medium uppercase tracking-wider text-xs overflow-hidden transition-all hover:bg-white/10 hover:border-white/40 active:scale-95 flex items-center gap-3 backdrop-blur-md">
						<span class="relative z-10">Wczytaj więcej</span>
						<svg
							class="relative z-10 w-4 h-4 transition-transform group-hover:translate-y-1"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round">
							<path d="M6 9l6 6 6-6" />
						</svg>
					</button>
				</div>
			)
		}

		<!-- Bottom Button -->
		<div class="bento-btn-wrapper">
			<a href="#history" class="btn-levelup">
				<span class="btn-label">Level Up</span>
				<svg
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="3"
					stroke-linecap="round"
					stroke-linejoin="round">
					<path d="M7 11l5-5 5 5"></path>
					<path d="M7 18l5-5 5 5"></path>
				</svg>
			</a>
		</div>
	</div>

	<!-- Custom Modal -->
	<div id="article-modal" class="modal-wrapper hidden">
		<div id="modal-backdrop" class="modal-backdrop"></div>

		<div id="modal-container" class="modal-container">
			<button id="close-modal" class="modal-close" aria-label="Zamknij">
				<svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none">
					<path d="M18 6L6 18M6 6l12 12"></path>
				</svg>
			</button>

			<div class="modal-hero">
				<img id="modal-img" src="" alt="" class="modal-img-element" />
				<div class="modal-hero-gradient"></div>
			</div>

			<div class="modal-body scrollbar-hide">
				<div class="modal-content-meta">
					<span id="modal-date" class="modal-content-date"></span>
					<span class="modal-content-dot"></span>
					<span class="modal-content-category">NF Team</span>
				</div>
				<h3 id="modal-title" class="modal-content-title" aria-label="Tytuł artykułu">&nbsp;</h3>
				<div id="modal-text" class="modal-content-text"></div>
			</div>
		</div>
	</div>
</section>

<style>
	/* SECTION LAYOUT */
	.blog-section {
		position: relative;
		padding: 8rem 0;
		background-color: #0b111d;
		min-height: 100vh;
		overflow: hidden;
	}

	.ambient-glow {
		position: absolute;
		border-radius: 50%;
		pointer-events: none;
		mix-blend-mode: screen;
		filter: blur(150px);
	}
	.glow-primary {
		top: 0;
		left: 25%;
		width: 800px;
		height: 800px;
		background-color: #a213da;
		opacity: 0.1;
	}
	.glow-secondary {
		bottom: 0;
		right: 25%;
		width: 600px;
		height: 600px;
		background-color: #a213da;
		opacity: 0.05;
	}

	.edge-fade {
		position: absolute;
		left: 0;
		right: 0;
		height: 150px;
		z-index: 10;
		pointer-events: none;
	}
	.edge-fade-top {
		top: 0;
		background: linear-gradient(to bottom, #0b111d 0%, transparent 100%);
	}
	.edge-fade-bottom {
		bottom: 0;
		background: linear-gradient(to top, #0b111d 0%, transparent 100%);
	}

	.bento-container {
		max-width: 1400px;
		margin: 0 auto;
		padding: 0 1.5rem;
		position: relative;
		z-index: 10;
	}

	/* HEADER */
	.bento-header {
		margin-bottom: 5rem;
		text-align: center;
		max-width: 56rem;
		margin-left: auto;
		margin-right: auto;
	}

	.bento-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.5rem 1rem;
		border-radius: 9999px;
		background-color: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.1);
		margin-bottom: 2rem;
		backdrop-filter: blur(12px);
	}
	.pulse-dot {
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 50%;
		background-color: #a213da;
		animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
	}
	@keyframes pulse {
		0%,
		100% {
			opacity: 1;
		}
		50% {
			opacity: 0.5;
		}
	}
	.badge-text {
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: rgba(255, 255, 255, 0.7);
		font-weight: 600;
	}

	.bento-heading {
		font-size: 2.25rem;
		line-height: 1.2;
		font-weight: 700;
		color: white;
		margin-bottom: 1.5rem;
		letter-spacing: -0.025em;
	}
	@media (min-width: 768px) {
		.bento-heading {
			font-size: 3.75rem;
		}
	}

	.bento-subheading {
		color: rgba(255, 255, 255, 0.5);
		font-size: 1.125rem;
		font-weight: 300;
	}
	@media (min-width: 768px) {
		.bento-subheading {
			font-size: 1.25rem;
		}
	}

	/* BOTTOM BUTTON */
	.bento-btn-wrapper {
		display: flex;
		justify-content: center;
		margin-top: 5rem;
		position: relative;
		z-index: 50;
	}
	.btn-levelup {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.85rem 2.5rem;
		border: 1px solid rgba(162, 19, 218, 0.45);
		border-radius: 999px;
		background: transparent;
		color: #fff;
		font-weight: 700;
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		text-decoration: none;
		transition: all 0.3s ease;
		cursor: pointer;
	}
	.btn-levelup svg {
		width: 16px;
		height: 16px;
		transition: transform 0.3s ease;
	}
	.btn-levelup:hover {
		background: rgba(162, 19, 218, 0.1);
		border-color: #a213da;
		box-shadow: 0 0 24px rgba(162, 19, 218, 0.3);
		transform: translateY(-4px);
	}
	.btn-levelup:active {
		transform: translateY(0) scale(0.98);
	}

	/* BENTO GRID CSS */
	.bento-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		grid-auto-rows: 320px;
		gap: 1.5rem;
	}

	.bento-card {
		position: relative;
		border-radius: 24px;
		cursor: pointer;
		border: 1px solid rgba(255, 255, 255, 0.05);
		transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1);
	}

	.bento-inner {
		position: absolute;
		inset: 0;
		border-radius: inherit;
		overflow: hidden;
		background: rgba(255, 255, 255, 0.02);
		z-index: 10;
	}

	.bento-card:hover {
		border-color: rgba(162, 19, 218, 0.4);
		box-shadow:
			0 20px 40px rgba(0, 0, 0, 0.4),
			0 0 40px rgba(162, 19, 218, 0.1);
		transform: translateY(-8px);
	}

	.bento-image-wrapper {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		border-radius: inherit;
		overflow: hidden;
	}

	.bento-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: inherit;
		transition: transform 0.7s cubic-bezier(0.19, 1, 0.22, 1);
	}

	.bento-card:hover .bento-img {
		transform: scale(1.08);
	}

	.bento-overlay {
		position: absolute;
		inset: 0;
		border-radius: inherit;
		background: linear-gradient(to top, rgba(11, 17, 29, 0.95) 0%, rgba(11, 17, 29, 0.4) 50%, transparent 100%);
		transition: background 0.5s ease;
	}

	.bento-card:hover .bento-overlay {
		background: linear-gradient(to top, rgba(11, 17, 29, 0.95) 0%, rgba(162, 19, 218, 0.2) 50%, transparent 100%);
	}

	.bento-content {
		position: absolute;
		bottom: 0;
		left: 0;
		width: 100%;
		padding: 2rem;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		z-index: 10;
	}

	.bento-meta {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 0.75rem;
	}
	.bento-arrow {
		width: 2rem;
		height: 2rem;
		border-radius: 50%;
		background-color: rgba(255, 255, 255, 0.1);
		backdrop-filter: blur(12px);
		display: flex;
		align-items: center;
		justify-content: center;
		opacity: 0;
		transform: translateX(1rem);
		transition: all 0.3s cubic-bezier(0.19, 1, 0.22, 1);
	}
	.bento-arrow-icon {
		color: white;
	}
	.bento-card:hover .bento-arrow {
		opacity: 1;
		transform: translateX(0);
	}

	.bento-date {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.8rem;
		color: #a213da;
		letter-spacing: 0.1em;
	}

	.bento-title {
		font-size: 1.5rem;
		font-weight: 700;
		color: white;
		margin-bottom: 0.5rem;
		line-height: 1.2;
		transition: color 0.3s ease;
	}

	.bento-card:hover .bento-title {
		color: #fff;
	}

	.bento-excerpt {
		color: rgba(255, 255, 255, 0.6);
		font-size: 0.95rem;
		line-height: 1.5;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	/* BENTO GRID SIZES */
	.item-0 {
		grid-column: span 2;
		grid-row: span 2;
	}
	.item-1 {
		grid-column: span 2;
		grid-row: span 1;
	}
	.item-2 {
		grid-column: span 1;
		grid-row: span 1;
	}
	.item-3 {
		grid-column: span 1;
		grid-row: span 1;
	}
	.item-4 {
		grid-column: span 2;
		grid-row: span 1;
	}
	.item-5 {
		grid-column: span 2;
		grid-row: span 1;
	}

	.item-0 .bento-title {
		font-size: 2.2rem;
	}

	/* Responsive Grid */
	@media (max-width: 1024px) {
		.bento-grid {
			grid-template-columns: repeat(2, 1fr);
		}
		.item-0,
		.item-1,
		.item-4,
		.item-5 {
			grid-column: span 2;
		}
		.item-2,
		.item-3 {
			grid-column: span 1;
		}
	}

	@media (max-width: 640px) {
		.bento-grid {
			display: flex;
			flex-direction: column;
		}
		.bento-card {
			height: 400px;
		}
	}

	/* ========= MODAL ========= */
	.modal-wrapper {
		position: fixed;
		inset: 0;
		z-index: 100;
		display: flex;
		align-items: center;
		justify-content: center;
		pointer-events: none;
	}
	.modal-wrapper.hidden {
		display: none;
	}
	.modal-wrapper.flex {
		display: flex;
	}

	.modal-backdrop {
		position: absolute;
		inset: 0;
		background-color: rgba(11, 17, 29, 0.8);
		backdrop-filter: blur(24px);
		opacity: 0;
		transition: opacity 0.5s ease;
	}

	.modal-container {
		position: relative;
		width: 100%;
		max-width: 64rem;
		margin: 0 1rem;
		max-height: 90vh;
		background-color: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 1.5rem;
		overflow: hidden;
		box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
		opacity: 0;
		transform: scale(0.95);
		transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1);
		display: flex;
		flex-direction: column;
		pointer-events: auto;
	}

	/* MODAL INTERNALS */
	.opacity-0 {
		opacity: 0 !important;
	}
	.opacity-100 {
		opacity: 1 !important;
	}
	.scale-95 {
		transform: scale(0.95) !important;
	}
	.scale-100 {
		transform: scale(1) !important;
	}

	.modal-close {
		position: absolute;
		top: 1.5rem;
		right: 1.5rem;
		z-index: 50;
		width: 3rem;
		height: 3rem;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		background-color: rgba(0, 0, 0, 0.5);
		border: 1px solid rgba(255, 255, 255, 0.2);
		color: white;
		cursor: pointer;
		backdrop-filter: blur(12px);
		transition:
			background-color 0.3s,
			transform 0.2s;
	}
	.modal-close:hover {
		background-color: #a213da;
		transform: scale(1.05);
	}
	.modal-close:active {
		transform: scale(0.95);
	}

	.modal-hero {
		width: 100%;
		height: 16rem;
		position: relative;
		overflow: hidden;
		flex-shrink: 0;
	}
	@media (min-width: 768px) {
		.modal-hero {
			height: 20rem;
		}
	}

	.modal-img-element {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.modal-hero-gradient {
		position: absolute;
		inset: 0;
		background: linear-gradient(to top, #111827 0%, transparent 100%);
	}

	.modal-body {
		padding: 2rem;
		overflow-y: auto;
		background-color: #111827;
		flex: 1;
	}
	@media (min-width: 768px) {
		.modal-body {
			padding: 3rem;
		}
	}

	.modal-content-meta {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-bottom: 1.5rem;
	}

	.modal-content-date {
		color: #a213da;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.875rem;
		letter-spacing: 0.1em;
	}
	.modal-content-dot {
		width: 0.25rem;
		height: 0.25rem;
		border-radius: 50%;
		background-color: rgba(255, 255, 255, 0.2);
	}
	.modal-content-category {
		color: rgba(255, 255, 255, 0.4);
		font-size: 0.875rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	.modal-content-title {
		font-size: 1.875rem;
		line-height: 1.25;
		font-weight: 700;
		color: white;
		margin-bottom: 2rem;
	}
	@media (min-width: 768px) {
		.modal-content-title {
			font-size: 2.25rem;
		}
	}

	.modal-content-text {
		color: rgba(255, 255, 255, 0.7);
		font-size: 1.125rem;
		line-height: 1.625;
	}

	.modal-content-text p {
		margin-bottom: 1.5rem;
	}

	/* Scrollbar hide for modal */
	.scrollbar-hide::-webkit-scrollbar {
		display: none;
	}
	.scrollbar-hide {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
</style>

<script>
	const cards = document.querySelectorAll('.bento-card');
	const modal = document.getElementById('article-modal');
	const backdrop = document.getElementById('modal-backdrop');
	const container = document.getElementById('modal-container');
	const closeBtn = document.getElementById('close-modal');

	const mTitle = document.getElementById('modal-title');
	const mDate = document.getElementById('modal-date');
	const mText = document.getElementById('modal-text');
	const mImg = document.getElementById('modal-img') as HTMLImageElement;

	const openModal = (card: HTMLElement) => {
		if (!modal || !backdrop || !container || !mTitle || !mDate || !mText || !mImg) return;

		// Populate Data
		mTitle.textContent = card.dataset.title || '';
		mDate.textContent = card.dataset.date || '';
		mText.innerHTML = `<p>${card.dataset.text}</p>`;
		mImg.src = card.dataset.img || '';

		// Open standard modal
		modal.classList.remove('hidden');
		modal.classList.add('flex');

		// Trigger Animations
		requestAnimationFrame(() => {
			backdrop.classList.remove('opacity-0');
			backdrop.classList.add('opacity-100');
			container.classList.remove('opacity-0', 'scale-95');
			container.classList.add('opacity-100', 'scale-100');
			document.body.style.overflow = 'hidden'; // lock scroll
		});
	};

	const closeModal = () => {
		if (!modal || !backdrop || !container) return;

		backdrop.classList.remove('opacity-100');
		backdrop.classList.add('opacity-0');
		container.classList.remove('opacity-100', 'scale-100');
		container.classList.add('opacity-0', 'scale-95');
		document.body.style.overflow = ''; // unlock scroll

		setTimeout(() => {
			modal.classList.remove('flex');
			modal.classList.add('hidden');
		}, 500);
	};

	cards.forEach(card => card.addEventListener('click', () => openModal(card as HTMLElement)));
	closeBtn?.addEventListener('click', closeModal);
	backdrop?.addEventListener('click', closeModal);

	// ESC to close
	document.addEventListener('keydown', e => {
		if (e.key === 'Escape') closeModal();
	});

	// Load More Logic
	const loadMoreBtn = document.getElementById('load-more-btn');
	const loadMoreWrapper = document.getElementById('load-more-wrapper');
	const allCards = document.querySelectorAll('.post-card') as NodeListOf<HTMLElement>;

	if (loadMoreBtn && allCards.length > 0) {
		loadMoreBtn.addEventListener('click', () => {
			let revealed = 0;
			allCards.forEach(post => {
				const isHidden = window.getComputedStyle(post).display === 'none';

				if (isHidden && revealed < 3) {
					post.classList.remove('hidden', 'md:block', 'max-md:hidden', 'max-md:opacity-0');
					post.style.display = 'block';

					setTimeout(() => {
						post.classList.remove('opacity-0', 'md:opacity-100');
						post.classList.add('opacity-100');
						post.style.opacity = '1';
					}, 50);

					revealed++;
				}
			});

			let stillHidden = false;
			allCards.forEach(post => {
				if (window.getComputedStyle(post).display === 'none' && post.style.display !== 'block') {
					stillHidden = true;
				}
			});

			if (!stillHidden && loadMoreWrapper) {
				loadMoreWrapper.style.display = 'none';
			}
		});
	}
</script>
