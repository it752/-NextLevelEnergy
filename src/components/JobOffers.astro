---
import { jobOffers } from '../data/jobs';
---

<section id="kariera" class="job-offers-section">
	<div class="job-offers-container">
		<!-- Left Column: List -->
		<div class="list-column">
			<div class="list-header">
				<h2 class="section-title">Kariera</h2>
				<p class="section-subtitle">Dołącz do ekipy The Next Level</p>
			</div>

			<div class="filters-container">
				<div class="custom-dropdown-container">
					<button
						class="custom-dropdown-trigger"
						id="city-filter-trigger"
						aria-haspopup="listbox"
						aria-expanded="false">
						<div class="trigger-content">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
								<circle cx="12" cy="10" r="3"></circle>
							</svg>
							<span id="selected-city-text">Wszystkie lokalizacje</span>
						</div>
						<svg
							class="dropdown-chevron"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2">
							<path d="M6 9l6 6 6-6"></path>
						</svg>
					</button>

					<div class="custom-dropdown-list" role="listbox" id="city-dropdown-list">
						<button class="dropdown-option is-selected" data-value="all" role="option" aria-selected="true"
							>Wszystkie lokalizacje</button
						>
						{
							Array.from(new Set(jobOffers.map(offer => offer.location))).map(loc => (
								<button class="dropdown-option" data-value={loc} role="option" aria-selected="false">
									{loc}
								</button>
							))
						}
					</div>
				</div>
			</div>

			<div class="offers-list">
				{
					jobOffers.map((offer, index) => (
						<button
							class="offer-card"
							data-index={index}
							data-location={offer.location}
							aria-label={`Zobacz szczegóły oferty ${offer.title}`}>
							<div class="offer-content">
								<h3 class="offer-title">{offer.title}</h3>
								<div class="offer-meta">
									<span class="meta-item salary">
										<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
											<path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
										</svg>
										{offer.salary}
									</span>
									<span class="meta-item location">
										<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
											<>
												<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
												<circle cx="12" cy="10" r="3" />
											</>
										</svg>
										{offer.location}
									</span>
								</div>
							</div>
							<div class="offer-arrow">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<path d="M5 12h14M12 5l7 7-7 7" />
								</svg>
							</div>
						</button>
					))
				}
			</div>
		</div>

		<!-- Right Column: Details & Forms -->
		<div class="details-column">
			<!-- State 0: Empty/Welcome State -->
			<div id="state-welcome" class="detail-state active-state">
				<div class="welcome-graphics">
					<div class="glow-orb primary"></div>
					<div class="glow-orb secondary"></div>

					<div class="welcome-center">
						<span class="nf-badge">NEXT LEVEL</span>
						<h3 class="welcome-title">Wybierz swoją ścieżkę</h3>
						<p class="welcome-desc">
							Kliknij interesującą Cię ofertę po lewej stronie, aby wyświetlić szczegóły i formularz
							aplikacyjny.
						</p>
					</div>

					<div class="grid-overlay"></div>
				</div>
			</div>

			<!-- State 1: Details -->
			<div id="state-details" class="detail-state">
				<!-- Injected by JS -->
				<div id="details-content-target" class="content-scrollable">
					<!-- Details will be rendered here -->
				</div>
			</div>
		</div>
	</div>

	<!-- Pushing data safely to JS -->
	<div id="job-data" data-offers={JSON.stringify(jobOffers)} style="display: none;"></div>

	<style>
		.job-offers-section {
			background: #0b111d;
			min-height: 100vh;
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			padding: 5rem 1.5rem;
			position: relative;
		}

		.job-offers-container {
			display: flex;
			max-width: 1400px;
			width: 100%;
			gap: 2rem;
			border-radius: 20px;
			/* Subtle glow rim for the whole container */
			background: rgba(15, 23, 42, 0.4);
			border: 1px solid rgba(255, 255, 255, 0.05);
			backdrop-filter: blur(20px);
			box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
			overflow: hidden;
			height: 80vh; /* Fixed height for internal scrolling */
			min-height: 700px;
		}

		/* Scrollbar styling for internal content */
		.content-scrollable {
			height: 100%;
			overflow-y: auto;
			padding-right: 0.5rem;
		}

		.content-scrollable::-webkit-scrollbar {
			width: 6px;
		}
		.content-scrollable::-webkit-scrollbar-track {
			background: rgba(255, 255, 255, 0.02);
			border-radius: 10px;
		}
		.content-scrollable::-webkit-scrollbar-thumb {
			background: rgba(162, 19, 218, 0.2);
			border-radius: 10px;
		}
		.content-scrollable::-webkit-scrollbar-thumb:hover {
			background: rgba(162, 19, 218, 0.5);
		}

		/* ======== LEFT COLUMN ======== */
		.list-column {
			width: 35%;
			border-right: 1px solid rgba(255, 255, 255, 0.05);
			display: flex;
			flex-direction: column;
			background: rgba(11, 17, 29, 0.6);
		}

		.list-header {
			padding: 2.5rem 2rem 1.5rem;
			border-bottom: 1px solid rgba(255, 255, 255, 0.05);
		}

		.filters-container {
			display: flex;
			gap: 0.5rem;
			padding: 1rem 1.5rem 0;
			flex-wrap: wrap;
		}

		.custom-dropdown-container {
			position: relative;
			width: 100%;
			max-width: 350px;
		}

		.custom-dropdown-trigger {
			display: flex;
			align-items: center;
			justify-content: space-between;
			width: 100%;
			background: rgba(255, 255, 255, 0.03);
			border: 1px solid rgba(255, 255, 255, 0.1);
			border-radius: 99px;
			padding: 0.8rem 1.5rem;
			cursor: pointer;
			transition: all 0.3s;
			color: white;
			font-weight: 600;
			font-size: 0.95rem;
		}

		.custom-dropdown-trigger:hover,
		.custom-dropdown-container.is-open .custom-dropdown-trigger {
			border-color: #a213da;
			background: rgba(162, 19, 218, 0.05);
		}

		.trigger-content {
			display: flex;
			align-items: center;
			gap: 0.8rem;
		}

		.trigger-content svg {
			width: 18px;
			height: 18px;
			color: #a213da;
			flex-shrink: 0;
		}

		.dropdown-chevron {
			width: 18px;
			height: 18px;
			color: rgba(255, 255, 255, 0.5);
			transition: transform 0.3s;
		}

		.custom-dropdown-container.is-open .dropdown-chevron {
			transform: rotate(180deg);
			color: #a213da;
		}

		.custom-dropdown-list {
			position: absolute;
			top: calc(100% + 0.5rem);
			left: 0;
			width: 100%;
			background: #0b111d;
			border: 1px solid rgba(162, 19, 218, 0.3);
			border-radius: 16px;
			box-shadow: 0 10px 40px rgba(0, 0, 0, 0.8);
			overflow: hidden;
			z-index: 100;
			opacity: 0;
			visibility: hidden;
			transform: translateY(-10px);
			transition: all 0.3s cubic-bezier(0.19, 1, 0.22, 1);
			display: flex;
			flex-direction: column;
		}

		.custom-dropdown-container.is-open .custom-dropdown-list {
			opacity: 1;
			visibility: visible;
			transform: translateY(0);
		}

		.dropdown-option {
			width: 100%;
			text-align: left;
			background: none;
			border: none;
			border-bottom: 1px solid rgba(255, 255, 255, 0.05);
			padding: 1rem 1.5rem;
			color: rgba(255, 255, 255, 0.7);
			font-size: 0.95rem;
			cursor: pointer;
			transition: all 0.2s;
		}

		.dropdown-option:last-child {
			border-bottom: none;
		}

		.dropdown-option:hover {
			background: rgba(162, 19, 218, 0.1);
			color: white;
			padding-left: 2rem;
		}

		.dropdown-option.is-selected {
			background: rgba(162, 19, 218, 0.15);
			color: #a213da;
			font-weight: 700;
		}

		.section-title {
			font-size: 2rem;
			font-weight: 800;
			color: white;
			margin-bottom: 0.2rem;
			text-transform: uppercase;
			letter-spacing: 0.05em;
		}

		.section-subtitle {
			font-size: 0.9rem;
			color: rgba(255, 255, 255, 0.5);
		}

		.offers-list {
			flex: 1;
			overflow-y: auto;
			padding: 1.5rem;
			display: flex;
			flex-direction: column;
			gap: 1rem;
		}

		/* Hide scrollbar for list but keep functionality */
		.offers-list::-webkit-scrollbar {
			display: none;
		}
		.offers-list {
			-ms-overflow-style: none;
			scrollbar-width: none;
		}

		.offer-card {
			background: rgba(255, 255, 255, 0.02);
			border: 1px solid rgba(255, 255, 255, 0.05);
			border-radius: 12px;
			padding: 1.5rem;
			text-align: left;
			cursor: pointer;
			display: flex;
			justify-content: space-between;
			align-items: center;
			transition: all 0.3s ease;
			color: white;
			position: relative;
			overflow: hidden;
		}

		/* Selected state and hover */
		.offer-card.is-active,
		.offer-card:hover {
			background: rgba(162, 19, 218, 0.1);
			border-color: rgba(162, 19, 218, 0.4);
			transform: translateX(5px);
		}

		.offer-card.is-active::before {
			content: '';
			position: absolute;
			left: 0;
			top: 0;
			height: 100%;
			width: 4px;
			background: #a213da;
		}

		.offer-title {
			font-size: 1.1rem;
			font-weight: 700;
			margin-bottom: 0.8rem;
			line-height: 1.3;
		}

		.offer-meta {
			display: flex;
			flex-wrap: wrap;
			gap: 1rem;
		}

		.meta-item {
			display: flex;
			align-items: center;
			gap: 0.4rem;
			font-size: 0.8rem;
			color: rgba(255, 255, 255, 0.6);
		}

		.meta-item svg {
			width: 14px;
			height: 14px;
			opacity: 0.7;
		}

		.salary {
			color: #a213da;
			font-weight: 600;
		}

		.offer-arrow {
			width: 32px;
			height: 32px;
			border-radius: 50%;
			background: rgba(255, 255, 255, 0.05);
			display: flex;
			align-items: center;
			justify-content: center;
			flex-shrink: 0;
			transition: all 0.3s;
		}

		.offer-arrow svg {
			width: 16px;
			height: 16px;
			color: rgba(255, 255, 255, 0.5);
			transition: color 0.3s;
		}

		.offer-card.is-active .offer-arrow,
		.offer-card:hover .offer-arrow {
			background: #a213da;
		}

		.offer-card.is-active .offer-arrow svg,
		.offer-card:hover .offer-arrow svg {
			color: white;
		}

		/* ======== RIGHT COLUMN (State Machine) ======== */
		.details-column {
			width: 65%;
			position: relative;
			overflow: hidden;
			background: url('data:image/svg+xml;utf8,<svg width="40" height="40" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg"><path d="M0 0h40v40H0V0zm20 20h20v20H20V20z" fill="rgba(255,255,255,0.01)"/></svg>');
		}

		.detail-state {
			position: absolute;
			inset: 0;
			padding: 3rem;
			opacity: 0;
			visibility: hidden;
			transform: translateX(20px);
			transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1);
			z-index: 1;
		}

		.detail-state.active-state {
			opacity: 1;
			visibility: visible;
			transform: translateX(0);
			z-index: 10;
		}

		/* WELCOME GRAPHICS (Zamiast Mapy) */
		.welcome-graphics {
			position: absolute;
			inset: 0;
			display: flex;
			align-items: center;
			justify-content: center;
			background: radial-gradient(circle at center, rgba(162, 19, 218, 0.05) 0%, transparent 60%);
		}

		.glow-orb {
			position: absolute;
			border-radius: 50%;
			filter: blur(80px);
			z-index: 0;
			opacity: 0.4;
			animation: drift 10s infinite alternate ease-in-out;
		}

		.glow-orb.primary {
			width: 400px;
			height: 400px;
			background: #a213da;
			top: 10%;
			right: -10%;
		}

		.glow-orb.secondary {
			width: 300px;
			height: 300px;
			background: #0047ff;
			bottom: -10%;
			left: 10%;
			animation-delay: -5s;
		}

		@keyframes drift {
			0% {
				transform: translate(0, 0) scale(1);
			}
			100% {
				transform: translate(-50px, 30px) scale(1.1);
			}
		}

		.welcome-center {
			position: relative;
			z-index: 2;
			text-align: center;
			padding: 2rem;
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 1rem;
		}

		.nf-badge {
			border: 1px solid rgba(255, 255, 255, 0.1);
			background: rgba(255, 255, 255, 0.02);
			backdrop-filter: blur(10px);
			padding: 0.4rem 1.2rem;
			border-radius: 99px;
			font-size: 0.8rem;
			font-weight: 800;
			color: #a213da;
			letter-spacing: 0.1em;
		}

		.welcome-title {
			font-size: 2.5rem;
			font-weight: 900;
			color: white;
			margin: 0;
		}

		.welcome-desc {
			color: rgba(255, 255, 255, 0.6);
			max-width: 350px;
			line-height: 1.5;
		}

		/* DYNAMIC DETAILS STYLES (Need :global because HTML is injected via JS ) */
		:global(.dyn-header) {
			margin-bottom: 2.5rem;
			position: relative;
		}

		:global(.dyn-back-mobile) {
			display: none; /* Only on mobile to return to list */
			align-items: center;
			gap: 0.5rem;
			color: #a213da;
			background: none;
			border: none;
			font-weight: 600;
			font-size: 0.9rem;
			margin-bottom: 1.5rem;
			padding: 0;
			cursor: pointer;
		}

		:global(.dyn-title) {
			font-size: 2.2rem;
			font-weight: 800;
			color: white;
			line-height: 1.2;
			margin-bottom: 1rem;
		}

		:global(.dyn-meta) {
			display: flex;
			gap: 2rem;
			padding-bottom: 1.5rem;
			border-bottom: 1px solid rgba(255, 255, 255, 0.1);
		}

		:global(.dyn-meta-item) {
			display: flex;
			align-items: center;
			gap: 0.5rem;
			color: #a213da;
			font-weight: 600;
		}
		:global(.dyn-meta-item svg) {
			width: 18px;
			height: 18px;
		}
		:global(.dyn-meta-item.location) {
			color: rgba(255, 255, 255, 0.7);
			font-weight: 400;
		}

		:global(.dyn-body h4) {
			font-size: 1.1rem;
			font-weight: 700;
			color: white;
			margin: 2rem 0 1rem;
		}

		:global(.dyn-desc) {
			color: rgba(255, 255, 255, 0.8);
			line-height: 1.7;
		}

		:global(.dyn-list) {
			list-style: none;
			padding: 0;
			display: flex;
			flex-direction: column;
			gap: 0.8rem;
		}

		:global(.dyn-list li) {
			color: rgba(255, 255, 255, 0.7);
			line-height: 1.5;
			position: relative;
			padding-left: 1.5rem;
		}

		:global(.dyn-list li::before) {
			content: '•';
			color: #a213da;
			font-size: 1.5rem;
			position: absolute;
			left: 0;
			top: -4px;
		}

		:global(.dyn-actions) {
			margin-top: 3rem;
			display: flex;
		}

		.btn-primary {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			gap: 0.8rem;
			padding: 1rem 2.5rem;
			background: #a213da;
			color: white;
			border: none;
			border-radius: 99px;
			font-weight: 700;
			font-size: 0.9rem;
			text-transform: uppercase;
			letter-spacing: 0.05em;
			cursor: pointer;
			transition: all 0.3s;
		}

		.btn-primary:hover {
			background: #b515f2;
			transform: translateY(-2px);
			box-shadow: 0 10px 20px rgba(162, 19, 218, 0.3);
		}

		.btn-primary svg {
			width: 18px;
			height: 18px;
		}

		/* CTA na dole */
		.offers-cta {
			display: flex;
			justify-content: center;
			margin-top: 3rem;
			width: 100%;
			z-index: 10;
		}

		.to-btn {
			display: inline-flex;
			align-items: center;
			gap: 0.5rem;
			padding: 0.85rem 2.5rem;
			border: 1px solid rgba(162, 19, 218, 0.45);
			border-radius: 999px;
			background: #0b111d;
			color: #fff;
			font-weight: 700;
			font-size: 0.85rem;
			text-transform: uppercase;
			letter-spacing: 0.1em;
			text-decoration: none;
			transition: all 0.3s ease;
			box-shadow: 0 5px 15px rgba(0, 0, 0, 0.5);
		}
		.to-btn svg {
			width: 16px;
			height: 16px;
			transition: transform 0.3s ease;
		}
		.to-btn:hover {
			background: rgba(162, 19, 218, 0.2);
			border-color: #a213da;
			box-shadow: 0 0 24px rgba(162, 19, 218, 0.5);
		}
		.to-btn:hover svg {
			transform: translateY(-3px);
		}

		/* RESPONSIVE DESIGN */
		@media (max-width: 1024px) {
			.job-offers-section {
				padding: 4rem 1rem;
			}
			.job-offers-container {
				flex-direction: column;
				height: 85vh;
				min-height: 800px;
			}

			/* Switch to Stacked UI */
			.list-column {
				width: 100%;
				height: 40%; /* Top area */
				border-right: none;
				border-bottom: 1px solid rgba(255, 255, 255, 0.05);
			}

			.details-column {
				width: 100%;
				height: 60%; /* Bottom area */
			}

			.detail-state {
				padding: 2rem 1.5rem;
			}
		}

		@media (max-width: 768px) {
			.job-offers-section {
				padding: 0;
				min-height: auto;
			}
			.job-offers-container {
				height: 100vh; /* Take full viewport height on mobile */
				border-radius: 0;
				border: none;
				min-height: auto;
			}

			/* Mobile - Offcanvas approach for Details */
			.list-column {
				height: 100%;
				border-bottom: none;
			}

			/* Move Details Column completely off-screen by default, overlaying the list */
			.details-column {
				position: absolute;
				inset: 0;
				height: 100%;
				background: #0b111d;
				transform: translateX(100%);
				transition: transform 0.4s ease;
				z-index: 50;
			}

			/* Class added by JS to body/container when offer selected */
			.job-offers-container.show-mobile-details .details-column {
				transform: translateX(0);
			}

			/* Enable the mobile back button */
			.dyn-back-mobile {
				display: flex;
			}

			.welcome-graphics {
				display: none;
			} /* Useless on mobile layered approach */

			/* Adjust paddings */
			.list-header {
				padding: 2rem 1.5rem 1rem;
			}
			.offers-list {
				padding: 1rem 1.5rem;
			}
		}
	</style>

	<script>
		// Safe data parsing
		const dataEl = document.getElementById('job-data');
		let jobOffers: any[] = [];
		try {
			jobOffers = dataEl ? JSON.parse(dataEl.getAttribute('data-offers') || '[]') : [];
		} catch (e) {
			console.error('Failed to parse job data', e);
		}

		// DOM Elements
		const container = document.querySelector('.job-offers-container');
		const offerCards = document.querySelectorAll('.offer-card');

		// State Containers
		const states = {
			welcome: document.getElementById('state-welcome'),
			details: document.getElementById('state-details'),
		};

		const detailsTarget = document.getElementById('details-content-target');

		// Active context
		let activeJobIndex = -1;

		// State Switcher Utility
		function switchState(targetStateKey: keyof typeof states) {
			Object.values(states).forEach(state => {
				if (state) state.classList.remove('active-state');
			});
			if (states[targetStateKey]) {
				states[targetStateKey].classList.add('active-state');

				// Scroll content back to top inside the container
				const scrollable = states[targetStateKey].querySelector('.content-scrollable');
				if (scrollable) scrollable.scrollTop = 0;
			}
		}

		// Render specific job details HTML
		function renderDetails(jobData: any) {
			if (!detailsTarget) return;

			const responsibilitiesHTML = jobData.responsibilities.map((r: string) => `<li>${r}</li>`).join('');
			const requirementsHTML = jobData.requirements.map((r: string) => `<li>${r}</li>`).join('');

			const jobUrl = '/kariera/' + jobData.id;

			const html = `
			<div class="dyn-header">
				<button class="dyn-back-mobile" aria-label="Wróc do listy">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
					Wróc do listy ofert
				</button>
				<h3 class="dyn-title">${jobData.title}</h3>
				<div class="dyn-meta">
					<div class="dyn-meta-item salary">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
						${jobData.salary}
					</div>
					<div class="dyn-meta-item location">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
						${jobData.location}
					</div>
				</div>
			</div>
			
			<div class="dyn-body">
				<h4>Opis stanowiska</h4>
				<p class="dyn-desc">${jobData.description}</p>
				
				<h4>Zakres obowiązków</h4>
				<ul class="dyn-list">
					${responsibilitiesHTML}
				</ul>

				<h4>Nasze wymagania</h4>
				<ul class="dyn-list">
					${requirementsHTML}
				</ul>

				<div class="dyn-actions">
					<a href="${jobUrl}" class="btn-primary">
						Aplikuj teraz
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
					</a>
				</div>
			</div>
		`;

			detailsTarget.innerHTML = html;
			bindDynamicListeners();
		}

		// Listeners for elements dynamically injected by renderDetails()
		function bindDynamicListeners() {
			const btnMobileBack = document.querySelector('.dyn-back-mobile');

			if (btnMobileBack) {
				btnMobileBack.addEventListener('click', () => {
					// Hide mobile overlay
					container?.classList.remove('show-mobile-details');
					// Reset active selection in list
					offerCards.forEach(c => c.classList.remove('is-active'));
					activeJobIndex = -1;
					// Reset to welcome state so it's ready for future use
					switchState('welcome');
				});
			}
		}

		// List Selection Logic
		offerCards.forEach(card => {
			card.addEventListener('click', () => {
				const indexStr = card.getAttribute('data-index');
				if (!indexStr) return;
				const idx = parseInt(indexStr);

				// UI state
				offerCards.forEach(c => c.classList.remove('is-active'));
				card.classList.add('is-active');

				// Trigger Mobile Slide-in
				container?.classList.add('show-mobile-details');

				// Load Data
				if (activeJobIndex !== idx && jobOffers[idx]) {
					activeJobIndex = idx;
					renderDetails(jobOffers[idx]);
					switchState('details');
				} else if (jobOffers[idx]) {
					// If already selected but maybe on mobile it needs to open again
					switchState('details');
				}
			});
		});

		// Filtering Logic by Custom Dropdown
		const dropdownContainer = document.querySelector('.custom-dropdown-container');
		const dropdownTrigger = document.querySelector('.custom-dropdown-trigger');
		const dropdownOptions = document.querySelectorAll('.dropdown-option');
		const selectedText = document.getElementById('selected-city-text');

		if (dropdownTrigger && dropdownContainer && selectedText) {
			dropdownTrigger.addEventListener('click', e => {
				e.stopPropagation();
				const isOpen = dropdownContainer.classList.contains('is-open');
				dropdownContainer.classList.toggle('is-open');
				dropdownTrigger.setAttribute('aria-expanded', (!isOpen).toString());
			});

			document.addEventListener('click', () => {
				dropdownContainer.classList.remove('is-open');
				dropdownTrigger.setAttribute('aria-expanded', 'false');
			});

			dropdownOptions.forEach(option => {
				option.addEventListener('click', e => {
					e.stopPropagation();

					// Update UI Selection
					dropdownOptions.forEach(opt => {
						opt.classList.remove('is-selected');
						opt.setAttribute('aria-selected', 'false');
					});

					option.classList.add('is-selected');
					option.setAttribute('aria-selected', 'true');
					selectedText.textContent = option.textContent;

					// Close Dropdown
					dropdownContainer.classList.remove('is-open');
					dropdownTrigger.setAttribute('aria-expanded', 'false');

					const filterValue = option.getAttribute('data-value');

					// Show/Hide cards
					offerCards.forEach(card => {
						const cardHtml = card as HTMLElement;
						if (filterValue === 'all' || cardHtml.getAttribute('data-location') === filterValue) {
							cardHtml.style.display = 'flex';
						} else {
							cardHtml.style.display = 'none';
						}
					});

					// If active card is hidden by filter, reset right panel
					const activeCard = Array.from(offerCards).find(c => c.classList.contains('is-active'));
					if (activeCard && (activeCard as HTMLElement).style.display === 'none') {
						activeCard.classList.remove('is-active');
						activeJobIndex = -1;
						switchState('welcome');
						container?.classList.remove('show-mobile-details');
					}
				});
			});
		}
	</script>
</section>
