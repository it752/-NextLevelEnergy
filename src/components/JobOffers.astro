---
// Dane oparte na strukturze Sanity, gotowe do podpięcia przez @sanity/client
const jobOffers = [
	{
		id: 'przedstawiciel-handlowy-oze',
		title: 'Przedstawiciel Handlowy ds. OZE',
		department: 'Sprzedaż',
		salary: '8 000 - 25 000 zł',
		location: 'Cala Polska',
		description:
			'Dołącz do struktur sprzedażowych i zostań twarzą transformacji energetycznej w Polsce. Szukamy osób zaangażowanych, nastawionych na cel i gotowych na ponadprzeciętne zyski w modelu B2B i B2C.',
		responsibilities: [
			'Aktywne pozyskiwanie klientów na rynku B2B / B2C',
			'Przeprowadzanie audytów energetycznych',
			'Doradztwo w zakresie rozwiązań odnawialnych źródeł energii',
			'Prowadzenie negocjacji i przygotowywanie ofert handlowych',
			'Utrzymywanie długofalowych relacji biznesowych',
		],
		requirements: [
			'Wysokie umiejętności komunikacyjne i negocjacyjne',
			'Doświadczenie w sprzedaży (mile widziana branża OZE)',
			'Nastawienie na realizację celów biznesowych',
			'Prawo jazdy kat. B',
			'Gotowość do pracy w terenie',
		],
	},
	{
		id: 'doradca-klienta-biznesowego',
		title: 'Doradca Klienta Biznesowego',
		department: 'Sprzedaż',
		salary: '12 000 - 30 000 zł',
		location: 'Trójmiasto / Warszawa',
		description:
			'Eksperckie stanowisko doradcze skierowane wyłącznie na sektor przedsiębiorstw średnich i dużych (MŚP i Enterprise).',
		responsibilities: [
			'Analiza profili energetycznych przedsiębiorstw',
			'Projektowanie dedykowanych rozwiązań OZE dla biznesu',
			'Współpraca z zarządami i dyrektorami finansowymi',
			'Monitorowanie i raportowanie wyników sprzedażowych',
		],
		requirements: [
			'Minimum 3-letnie doświadczenie w sprzedaży B2B',
			'Znajomość specyfiki rynku energetycznego (mile widziana)',
			'Umiejętność prezentowania danych finansowych (ROI, LCOE)',
			'Samodzielność w organizacji pracy własnej',
		],
	},
	{
		id: 'inzynier-projektant-pv',
		title: 'Inżynier Projektant Instalacji',
		department: 'Inżynieria',
		salary: '9 000 - 15 000 zł',
		location: 'Gdańsk',
		description:
			'Kluczowe stanowisko zaplecza inżynieryjnego. Twoim zadaniem będzie tworzenie koncepcji i projektów instalacji PV, magazynów energii i stacji ładowania EV.',
		responsibilities: [
			'Sporządzanie projektów koncepcyjnych i wykonawczych PV',
			'Wykonywanie analiz nasłonecznienia i doborów sprzętowych',
			'Wsparcie techniczne dla działu handlowego',
			'Weryfikacja warunków przyłączeniowych i dokumentacji',
		],
		requirements: [
			'Wykształcenie techniczne (Kierunki: Elektrotechnika, OZE itp.)',
			'Dobra znajomość programów CAD (AutoCAD, PVSyst, PV*SOL)',
			'Uprawnienia SEP do 1kV (mile widziane)',
			'Zdolność analitycznego myślenia',
		],
	},
	{
		id: 'koordynator-ds-montazu',
		title: 'Koordynator Działu Montaży',
		department: 'Montaż',
		salary: '7 000 - 12 000 zł',
		location: 'Polska Północna',
		description:
			'Osoba odpowiedzialna za sprawny i bezproblemowy przebieg procesu inwestycyjnego od podpisania umowy do uruchomienia instalacji.',
		responsibilities: [
			'Planowanie i koordynacja pracy ekip monterskich',
			'Zamawianie komponentów i zarządzanie logistyką na obiekty',
			'Odbiory techniczne instalacji fotowoltaicznych',
			'Dbanie o przestrzeganie procedur BHP',
		],
		requirements: [
			'Zdolności organizacyjne i umiejętność pracy pod presją czasu',
			'Doświadczenie na podobnym stanowisku',
			'Znajomość prawa budowlanego (w podstawowym zakresie)',
			'Czynne prawo jazdy kat. B',
		],
	},
];
---

<section id="kariera" class="job-offers-section">
	<div class="job-offers-container">
		<!-- Left Column: List -->
		<div class="list-column">
			<div class="list-header">
				<h2 class="section-title">Kariera</h2>
				<p class="section-subtitle">Dołącz do ekipy The Next Level</p>
			</div>

			<div class="filters-container">
				<div class="city-filter-wrapper">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
						<circle cx="12" cy="10" r="3"></circle>
					</svg>
					<select id="city-filter" class="city-selector" aria-label="Filtruj po lokalizacji">
						<option value="all">Wszystkie lokalizacje</option>
						{
							Array.from(new Set(jobOffers.map(offer => offer.location))).map(loc => (
								<option value={loc}>{loc}</option>
							))
						}
					</select>
				</div>
			</div>

			<div class="offers-list">
				{
					jobOffers.map((offer, index) => (
						<button
							class="offer-card"
							data-index={index}
							data-location={offer.location}
							aria-label={`Zobacz szczegóły oferty ${offer.title}`}>
							<div class="offer-content">
								<h3 class="offer-title">{offer.title}</h3>
								<div class="offer-meta">
									<span class="meta-item salary">
										<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
											<path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
										</svg>
										{offer.salary}
									</span>
									<span class="meta-item location">
										<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
											<>
												<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
												<circle cx="12" cy="10" r="3" />
											</>
										</svg>
										{offer.location}
									</span>
								</div>
							</div>
							<div class="offer-arrow">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<path d="M5 12h14M12 5l7 7-7 7" />
								</svg>
							</div>
						</button>
					))
				}
			</div>
		</div>

		<!-- Right Column: Details & Forms -->
		<div class="details-column">
			<!-- State 0: Empty/Welcome State -->
			<div id="state-welcome" class="detail-state active-state">
				<div class="welcome-graphics">
					<div class="glow-orb primary"></div>
					<div class="glow-orb secondary"></div>

					<div class="welcome-center">
						<span class="nf-badge">NEXT LEVEL</span>
						<h3 class="welcome-title">Wybierz swoją ścieżkę</h3>
						<p class="welcome-desc">
							Kliknij interesującą Cię ofertę po lewej stronie, aby wyświetlić szczegóły i formularz
							aplikacyjny.
						</p>
					</div>

					<div class="grid-overlay"></div>
				</div>
			</div>

			<!-- State 1: Details -->
			<div id="state-details" class="detail-state">
				<!-- Injected by JS -->
				<div id="details-content-target" class="content-scrollable">
					<!-- Details will be rendered here -->
				</div>
			</div>

			<!-- State 2: App Form Step 1 -->
			<div id="state-form-step1" class="detail-state">
				<div class="form-wrapper content-scrollable">
					<div class="form-header">
						<button class="back-link btn-back-to-details" aria-label="Wróc do szczegółów">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
								><path d="M19 12H5M12 19l-7-7 7-7"></path></svg
							>
							Powrót do oferty
						</button>
						<h3 class="form-title">Formularz aplikacyjny</h3>
						<span class="form-step">Krok 1 / 2</span>
					</div>

					<form id="app-form" class="app-form">
						<div class="input-wrapper">
							<label for="app_name">Imię</label>
							<input type="text" id="app_name" required placeholder="Wpisz Twoje Imię" />
						</div>

						<div class="input-wrapper">
							<label for="app_surname">Nazwisko</label>
							<input type="text" id="app_surname" required placeholder="Wpisz Twoje Nazwisko" />
						</div>

						<div class="input-wrapper">
							<label for="app_email">E-mail</label>
							<input type="email" id="app_email" required placeholder="Wpisz Twój Adres E-mail" />
						</div>

						<div class="input-wrapper">
							<label for="app_phone">Telefon</label>
							<input type="tel" id="app_phone" required placeholder="Wpisz Twój Numer Telefonu" />
						</div>

						<div class="input-wrapper">
							<label for="app_city">Miasto</label>
							<input type="text" id="app_city" required placeholder="Wpisz Twoje Miasto" />
						</div>

						<div class="form-actions right">
							<button type="button" id="btn-next-step" class="btn-primary">
								Następny krok
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
									><path d="M5 12h14M12 5l7 7-7 7"></path></svg
								>
							</button>
						</div>
					</form>
				</div>
			</div>

			<!-- State 3: App Form Step 2 -->
			<div id="state-form-step2" class="detail-state">
				<div class="form-wrapper content-scrollable">
					<div class="form-header">
						<button class="back-link btn-back-to-step1" aria-label="Wróć do kroku pierwszego">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
								><path d="M19 12H5M12 19l-7-7 7-7"></path></svg
							>
							Powrót do danych
						</button>
						<h3 class="form-title">Formularz aplikacyjny</h3>
						<span class="form-step">Krok 2 / 2</span>
					</div>

					<form id="app-form-final" class="app-form">
						<div class="input-wrapper select-group">
							<label for="app_type">Typ współpracy</label>
							<select id="app_type" required>
								<option value="" disabled selected>Preferowana forma zatrudnienia</option>
								<option value="b2b">B2B</option>
								<option value="uz">Umowa Zlecenie</option>
								<option value="uop">Umowa o Pracę</option>
							</select>
						</div>

						<div class="radio-section">
							<p class="radio-label">Prawo jazdy kategorii B:</p>
							<div class="radio-group">
								<label class="radio-custom">
									<input type="radio" name="driver_license" value="yes" required checked />
									<span class="radio-mark"></span>
									Posiadam
								</label>
								<label class="radio-custom">
									<input type="radio" name="driver_license" value="no" required />
									<span class="radio-mark"></span>
									Nie posiadam
								</label>
							</div>
						</div>

						<div class="file-upload-section">
							<label class="file-dropzone" for="cv_upload">
								<input type="file" id="cv_upload" accept=".pdf,.doc,.docx" hidden />
								<div class="drop-content">
									<svg
										viewBox="0 0 24 24"
										fill="none"
										stroke="#A213DA"
										stroke-width="2"
										width="32"
										height="32">
										<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
										<polyline points="17 8 12 3 7 8"></polyline>
										<line x1="12" y1="3" x2="12" y2="15"></line>
									</svg>
									<span class="drop-title">Załącz CV</span>
									<span class="drop-desc">Dostępne formaty: pdf, doc, docx</span>
									<span id="file-name-display" class="file-chosen-text"></span>
								</div>
							</label>
						</div>

						<div class="checkbox-group">
							<label class="custom-checkbox">
								<input type="checkbox" required />
								<span class="checkmark"></span>
								<span class="check-text">
									Wyrażam zgodę na przetwarzanie moich danych osobowych przez The Next Level w celu
									prowadzenia rekrutacji na aplikowane stanowisko.
								</span>
							</label>
						</div>

						<div class="form-actions right">
							<button type="submit" id="btn-submit-form" class="btn-primary success-variant">
								Wyślij aplikację
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
									><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"></path></svg
								>
							</button>
						</div>
					</form>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- Pushing data safely to JS -->
<div id="job-data" data-offers={JSON.stringify(jobOffers)} style="display: none;"></div>

<style>
	.job-offers-section {
		background: #0b111d;
		min-height: 100vh;
		display: flex;
		justify-content: center;
		padding: 5rem 1.5rem;
		position: relative;
	}

	.job-offers-container {
		display: flex;
		max-width: 1400px;
		width: 100%;
		gap: 2rem;
		border-radius: 20px;
		/* Subtle glow rim for the whole container */
		background: rgba(15, 23, 42, 0.4);
		border: 1px solid rgba(255, 255, 255, 0.05);
		backdrop-filter: blur(20px);
		box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
		overflow: hidden;
		height: 80vh; /* Fixed height for internal scrolling */
		min-height: 700px;
	}

	/* Scrollbar styling for internal content */
	.content-scrollable {
		height: 100%;
		overflow-y: auto;
		padding-right: 0.5rem;
	}

	.content-scrollable::-webkit-scrollbar {
		width: 6px;
	}
	.content-scrollable::-webkit-scrollbar-track {
		background: rgba(255, 255, 255, 0.02);
		border-radius: 10px;
	}
	.content-scrollable::-webkit-scrollbar-thumb {
		background: rgba(162, 19, 218, 0.2);
		border-radius: 10px;
	}
	.content-scrollable::-webkit-scrollbar-thumb:hover {
		background: rgba(162, 19, 218, 0.5);
	}

	/* ======== LEFT COLUMN ======== */
	.list-column {
		width: 35%;
		border-right: 1px solid rgba(255, 255, 255, 0.05);
		display: flex;
		flex-direction: column;
		background: rgba(11, 17, 29, 0.6);
	}

	.list-header {
		padding: 2.5rem 2rem 1.5rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
	}

	.filters-container {
		display: flex;
		gap: 0.5rem;
		padding: 1rem 1.5rem 0;
		flex-wrap: wrap;
	}

	.city-filter-wrapper {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 99px;
		padding: 0.6rem 1.2rem;
		width: 100%;
		max-width: 300px;
		transition: all 0.3s;
	}

	.city-filter-wrapper:focus-within {
		border-color: #a213da;
		background: rgba(162, 19, 218, 0.05);
	}

	.city-filter-wrapper svg {
		width: 16px;
		height: 16px;
		color: #a213da;
		flex-shrink: 0;
	}

	.city-selector {
		background: transparent;
		border: none;
		color: white;
		font-size: 0.9rem;
		font-weight: 600;
		width: 100%;
		outline: none;
		cursor: pointer;
	}

	.city-selector option {
		background: #0b111d;
		color: white;
	}

	.section-title {
		font-size: 2rem;
		font-weight: 800;
		color: white;
		margin-bottom: 0.2rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.section-subtitle {
		font-size: 0.9rem;
		color: rgba(255, 255, 255, 0.5);
	}

	.offers-list {
		flex: 1;
		overflow-y: auto;
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	/* Hide scrollbar for list but keep functionality */
	.offers-list::-webkit-scrollbar {
		display: none;
	}
	.offers-list {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}

	.offer-card {
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid rgba(255, 255, 255, 0.05);
		border-radius: 12px;
		padding: 1.5rem;
		text-align: left;
		cursor: pointer;
		display: flex;
		justify-content: space-between;
		align-items: center;
		transition: all 0.3s ease;
		color: white;
		position: relative;
		overflow: hidden;
	}

	/* Selected state and hover */
	.offer-card.is-active,
	.offer-card:hover {
		background: rgba(162, 19, 218, 0.1);
		border-color: rgba(162, 19, 218, 0.4);
		transform: translateX(5px);
	}

	.offer-card.is-active::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0;
		height: 100%;
		width: 4px;
		background: #a213da;
	}

	.offer-title {
		font-size: 1.1rem;
		font-weight: 700;
		margin-bottom: 0.8rem;
		line-height: 1.3;
	}

	.offer-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.meta-item {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.8rem;
		color: rgba(255, 255, 255, 0.6);
	}

	.meta-item svg {
		width: 14px;
		height: 14px;
		opacity: 0.7;
	}

	.salary {
		color: #a213da;
		font-weight: 600;
	}

	.offer-arrow {
		width: 32px;
		height: 32px;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.05);
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		transition: all 0.3s;
	}

	.offer-arrow svg {
		width: 16px;
		height: 16px;
		color: rgba(255, 255, 255, 0.5);
		transition: color 0.3s;
	}

	.offer-card.is-active .offer-arrow,
	.offer-card:hover .offer-arrow {
		background: #a213da;
	}

	.offer-card.is-active .offer-arrow svg,
	.offer-card:hover .offer-arrow svg {
		color: white;
	}

	/* ======== RIGHT COLUMN (State Machine) ======== */
	.details-column {
		width: 65%;
		position: relative;
		overflow: hidden;
		background: url('data:image/svg+xml;utf8,<svg width="40" height="40" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg"><path d="M0 0h40v40H0V0zm20 20h20v20H20V20z" fill="rgba(255,255,255,0.01)"/></svg>');
	}

	.detail-state {
		position: absolute;
		inset: 0;
		padding: 3rem;
		opacity: 0;
		visibility: hidden;
		transform: translateX(20px);
		transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1);
		z-index: 1;
	}

	.detail-state.active-state {
		opacity: 1;
		visibility: visible;
		transform: translateX(0);
		z-index: 10;
	}

	/* WELCOME GRAPHICS (Zamiast Mapy) */
	.welcome-graphics {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		background: radial-gradient(circle at center, rgba(162, 19, 218, 0.05) 0%, transparent 60%);
	}

	.glow-orb {
		position: absolute;
		border-radius: 50%;
		filter: blur(80px);
		z-index: 0;
		opacity: 0.4;
		animation: drift 10s infinite alternate ease-in-out;
	}

	.glow-orb.primary {
		width: 400px;
		height: 400px;
		background: #a213da;
		top: 10%;
		right: -10%;
	}

	.glow-orb.secondary {
		width: 300px;
		height: 300px;
		background: #0047ff;
		bottom: -10%;
		left: 10%;
		animation-delay: -5s;
	}

	@keyframes drift {
		0% {
			transform: translate(0, 0) scale(1);
		}
		100% {
			transform: translate(-50px, 30px) scale(1.1);
		}
	}

	.welcome-center {
		position: relative;
		z-index: 2;
		text-align: center;
		padding: 2rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
	}

	.nf-badge {
		border: 1px solid rgba(255, 255, 255, 0.1);
		background: rgba(255, 255, 255, 0.02);
		backdrop-filter: blur(10px);
		padding: 0.4rem 1.2rem;
		border-radius: 99px;
		font-size: 0.8rem;
		font-weight: 800;
		color: #a213da;
		letter-spacing: 0.1em;
	}

	.welcome-title {
		font-size: 2.5rem;
		font-weight: 900;
		color: white;
		margin: 0;
	}

	.welcome-desc {
		color: rgba(255, 255, 255, 0.6);
		max-width: 350px;
		line-height: 1.5;
	}

	/* DYNAMIC DETAILS STYLES */
