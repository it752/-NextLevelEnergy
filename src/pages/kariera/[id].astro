---
import Layout from '../../layouts/Layout.astro';
import { sanityClient } from 'sanity:client';

interface JobOffer {
	id: string;
	title: string;
	department: string;
	salary: string;
	location: string;
	description: any;
	responsibilities: any;
	requirements: any;
}

export async function getStaticPaths() {
	const offers: any[] = await sanityClient.fetch(`*[_type == "jobOffer"]`);
	return offers.map((offer: any, index: number) => ({
		params: { id: offer.slug.current },
		props: { offer, index },
	}));
}

const { offer } = Astro.props;
---

<Layout title={`${offer.title} - Kariera | Level Up`} description={offer.description}>
	<nav class="navbar-simple">
		<a href="/#kariera" class="back-link">
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
				<path d="M19 12H5M12 19l-7-7 7-7"></path>
			</svg>
			Wróć do listy ofert
		</a>
	</nav>

	<main class="job-split-layout">
		<!-- Left Side: Offer Details -->
		<div class="job-info-column">
			<div class="job-header">
				<h1 class="job-title">{offer.title}</h1>
				<div class="job-meta">
					<span class="meta-item">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
						</svg>
						{offer.salary}
					</span>
					<span class="meta-item location">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
							<circle cx="12" cy="10" r="3"></circle>
						</svg>
						{offer.location}
					</span>
				</div>
			</div>

			<div class="job-body">
				<h4>Opis stanowiska</h4>
				<p class="dyn-desc">{offer.description}</p>

				<h4>Zakres obowiązków</h4>
				<ul class="dyn-list">
					{offer.responsibilities.map((item: string) => <li>{item}</li>)}
				</ul>

				<h4>Nasze wymagania</h4>
				<ul class="dyn-list">
					{offer.requirements.map((item: string) => <li>{item}</li>)}
				</ul>
			</div>
		</div>

		<!-- Right Side: Application Form Container -->
		<div class="job-form-column">
			<div class="form-card-wrapper">
				<div class="form-card">
					<!-- Step 1 -->
					<div id="form-step-1" class="form-step active">
						<div class="form-header">
							<h3 class="form-title">Formularz aplikacyjny</h3>
							<span class="form-step-indicator">Krok 1 / 2</span>
						</div>

						<form id="app-form-1" class="app-form">
							<div class="input-wrapper">
								<label for="app_name">Imię</label>
								<input type="text" id="app_name" name="name" required placeholder="Wpisz Twoje Imię" />
							</div>

							<div class="input-wrapper">
								<label for="app_surname">Nazwisko</label>
								<input
									type="text"
									id="app_surname"
									name="surname"
									required
									placeholder="Wpisz Twoje Nazwisko"
								/>
							</div>

							<div class="input-wrapper">
								<label for="app_email">E-mail</label>
								<input
									type="email"
									id="app_email"
									name="email"
									required
									placeholder="Wpisz Twój Adres E-mail"
								/>
							</div>

							<div class="input-wrapper">
								<label for="app_phone">Telefon</label>
								<input
									type="tel"
									id="app_phone"
									name="phone"
									required
									placeholder="Wpisz Twój Numer Telefonu"
								/>
							</div>

							<div class="input-wrapper">
								<label for="app_city">Miasto</label>
								<input
									type="text"
									id="app_city"
									name="city"
									required
									placeholder="Wpisz Twoje Miasto"
								/>
							</div>

							<div class="form-actions center">
								<button type="submit" class="btn-primary w-full">
									Następny krok
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<path d="M5 12h14M12 5l7 7-7 7"></path>
									</svg>
								</button>
							</div>
						</form>
					</div>

					<!-- Step 2 -->
					<div id="form-step-2" class="form-step">
						<div class="form-header">
							<button type="button" class="back-link btn-back-step" aria-label="Wróć do kroku pierwszego">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<path d="M19 12H5M12 19l-7-7 7-7"></path>
								</svg>
								Powrót do danych
							</button>
							<h3 class="form-title mt-4">Formularz aplikacyjny</h3>
							<span class="form-step-indicator">Krok 2 / 2</span>
						</div>

						<form id="app-form-final" class="app-form">
							<div class="input-wrapper select-group">
								<label for="app_type">Typ współpracy</label>
								<select id="app_type" name="contractType" required>
									<option value="" disabled selected>Preferowana forma zatrudnienia</option>
									<option value="b2b">B2B</option>
									<option value="uz">Umowa Zlecenie</option>
									<option value="uop">Umowa o Pracę</option>
								</select>
							</div>

							<div class="radio-section">
								<p class="radio-label">Prawo jazdy kategorii B:</p>
								<div class="radio-group">
									<label class="radio-custom">
										<input type="radio" name="driver_license" value="yes" required checked />
										<span class="radio-mark"></span>
										Posiadam
									</label>
									<label class="radio-custom">
										<input type="radio" name="driver_license" value="no" required />
										<span class="radio-mark"></span>
										Nie posiadam
									</label>
								</div>
							</div>

							<div class="file-upload-section">
								<label class="file-dropzone" for="cv_upload">
									<input type="file" id="cv_upload" name="cvFile" accept=".pdf,.doc,.docx" hidden />
									<div class="drop-content">
										<svg
											viewBox="0 0 24 24"
											fill="none"
											stroke="#A213DA"
											stroke-width="2"
											width="32"
											height="32">
											<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
											<polyline points="17 8 12 3 7 8"></polyline>
											<line x1="12" y1="3" x2="12" y2="15"></line>
										</svg>
										<span class="drop-title">Załącz CV</span>
										<span class="drop-desc">Dostępne formaty: pdf, doc, docx</span>
										<span id="file-name-display" class="file-chosen-text"></span>
									</div>
								</label>
							</div>

							<div class="checkbox-group">
								<label class="custom-checkbox">
									<input type="checkbox" required />
									<span class="checkmark"></span>
									<span class="check-text">
										Wyrażam zgodę na przetwarzanie moich danych osobowych przez The Next Level w
										celu prowadzenia rekrutacji na aplikowane stanowisko.
									</span>
								</label>
							</div>

							<div class="form-actions center mt-6">
								<button type="submit" id="btn-submit-form" class="btn-primary w-full">
									Wyślij aplikację
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"></path>
									</svg>
								</button>
							</div>

							<!-- Success State Message -->
							<div id="form-success-msg" class="success-message" style="display: none;">
								<div class="success-icon">
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
										<polyline points="22 4 12 14.01 9 11.01"></polyline>
									</svg>
								</div>
								<h4>Aplikacja wysłana!</h4>
								<p>Dziękujemy za zgłoszenie. Skontaktujemy się z Tobą wkrótce.</p>
								<button type="button" class="btn-primary w-full reset-form-btn mt-4"
									>Wyślij kolejną</button
								>
							</div>
						</form>
					</div>
				</div>
			</div>
		</div>
	</main>

	<style>
		/* Global layout */
		.navbar-simple {
			padding: 2rem 5%;
			background: #0b111d;
			border-bottom: 1px solid rgba(255, 255, 255, 0.05);
		}
		.back-link {
			display: inline-flex;
			align-items: center;
			gap: 0.5rem;
			color: #a213da;
			text-decoration: none;
			font-weight: 600;
			font-size: 0.95rem;
			transition: transform 0.3s;
			background: none;
			border: none;
			cursor: pointer;
			padding: 0;
			text-align: left;
			line-height: 1.2;
		}
		.back-link:hover {
			transform: translateX(-5px);
		}

		.job-split-layout {
			background: #0b111d;
			min-height: 100vh;
			color: white;
			padding: 4rem 5%;
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 4rem;
			max-width: 1400px;
			margin: 0 auto;
		}

		/* Left Column - Job Info */
		.job-info-column {
			max-width: 600px;
		}

		.job-header {
			margin-bottom: 3rem;
			padding-bottom: 2rem;
			border-bottom: 1px solid rgba(255, 255, 255, 0.1);
		}

		.job-title {
			font-size: clamp(2rem, 4vw, 3rem);
			font-weight: 900;
			line-height: 1.2;
			margin-bottom: 1rem;
		}

		.job-meta {
			display: flex;
			gap: 2rem;
			flex-wrap: wrap;
		}

		.meta-item {
			display: flex;
			align-items: center;
			gap: 0.5rem;
			color: #a213da;
			font-size: 1rem;
			font-weight: 600;
		}

		.meta-item.location {
			color: rgba(255, 255, 255, 0.7);
			font-weight: 400;
		}

		.meta-item svg {
			width: 18px;
			height: 18px;
		}

		/* Dyn Typography matched with previous */
		.job-body h4 {
			font-size: 1.1rem;
			font-weight: 700;
			color: white;
			margin: 2.5rem 0 1rem;
		}

		.dyn-desc {
			color: rgba(255, 255, 255, 0.8);
			line-height: 1.7;
		}

		.dyn-list {
			list-style: none;
			padding: 0;
			display: flex;
			flex-direction: column;
			gap: 0.8rem;
		}

		.dyn-list li {
			color: rgba(255, 255, 255, 0.7);
			line-height: 1.5;
			position: relative;
			padding-left: 1.5rem;
		}

		.dyn-list li::before {
			content: '•';
			color: #a213da;
			font-size: 1.5rem;
			position: absolute;
			left: 0;
			top: -4px;
		}

		/* Right Column - Application Form */
		.form-card-wrapper {
			position: sticky;
			top: 2rem;
			border-radius: 20px;
			padding: 2px; /* For the animated border */
			background: linear-gradient(0deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.05));
			overflow: hidden;
			min-height: 500px;
			display: flex;
			box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
		}

		.form-card-wrapper::before {
			content: '';
			position: absolute;
			inset: -50%;
			background: conic-gradient(
				from 0deg,
				transparent 0deg,
				transparent 60deg,
				#a213da 120deg,
				transparent 180deg,
				transparent 240deg,
				#0047ff 300deg,
				transparent 360deg
			);
			animation: rotateBorder 6s linear infinite;
			opacity: 0.8;
		}

		@keyframes rotateBorder {
			0% {
				transform: rotate(0deg);
			}
			100% {
				transform: rotate(360deg);
			}
		}

		.form-card {
			background: #0b111d;
			border-radius: 19px; /* Slightly less than wrapper */
			padding: 3rem;
			width: 100%;
			position: relative;
			z-index: 1;
			display: flex;
			flex-direction: column;
		}

		.form-step {
			display: none;
			animation: fadeIn 0.4s ease forwards;
		}

		.form-step.active {
			display: block;
		}

		@keyframes fadeIn {
			from {
				opacity: 0;
				transform: translateX(10px);
			}
			to {
				opacity: 1;
				transform: translateX(0);
			}
		}

		.form-header {
			margin-bottom: 2rem;
		}

		.form-title {
			font-size: 1.5rem;
			font-weight: 800;
			margin-bottom: 0.5rem;
			margin-top: 0;
		}

		.form-step-indicator {
			font-size: 0.85rem;
			color: rgba(255, 255, 255, 0.5);
			font-weight: 600;
		}

		.mt-4 {
			margin-top: 1rem;
		}

		.app-form {
			display: flex;
			flex-direction: column;
			gap: 1.25rem;
		}

		.input-wrapper {
			display: flex;
			flex-direction: column;
			gap: 0.5rem;
		}

		.input-wrapper label {
			font-size: 0.85rem;
			color: rgba(255, 255, 255, 0.7);
			font-weight: 500;
		}

		.input-wrapper input,
		.input-wrapper select {
			width: 100%;
			background: rgba(255, 255, 255, 0.03);
			border: 1px solid rgba(255, 255, 255, 0.1);
			border-radius: 8px;
			padding: 0.9rem 1rem;
			color: white;
			font-size: 0.95rem;
			font-family: inherit;
			transition: all 0.3s;
		}

		.input-wrapper select {
			appearance: none;
			cursor: pointer;
			background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='rgba(255,255,255,0.5)' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
			background-repeat: no-repeat;
			background-position: right 1rem center;
			background-size: 1em;
		}

		.input-wrapper select option {
			background: #0b111d;
			color: white;
			padding: 1rem;
		}

		.input-wrapper input:focus,
		.input-wrapper select:focus {
			outline: none;
			border-color: #a213da;
			background: rgba(255, 255, 255, 0.05);
		}

		.input-wrapper input::placeholder {
			color: rgba(255, 255, 255, 0.3);
		}

		/* Radio Section */
		.radio-section {
			margin-top: 0.5rem;
		}

		.radio-label {
			font-size: 0.85rem;
			color: rgba(255, 255, 255, 0.7);
			font-weight: 500;
			margin-bottom: 0.8rem;
		}

		.radio-group {
			display: flex;
			gap: 2rem;
		}

		.radio-custom {
			display: flex;
			align-items: center;
			gap: 0.5rem;
			cursor: pointer;
			font-size: 0.9rem;
			color: rgba(255, 255, 255, 0.8);
		}

		.radio-custom input {
			display: none;
		}

		.radio-mark {
			width: 18px;
			height: 18px;
			border: 1px solid rgba(255, 255, 255, 0.3);
			border-radius: 50%;
			display: inline-block;
			position: relative;
			transition: all 0.3s;
		}

		.radio-custom input:checked + .radio-mark {
			border-color: #a213da;
		}

		.radio-custom input:checked + .radio-mark::after {
			content: '';
			position: absolute;
			top: 50%;
			left: 50%;
			transform: translate(-50%, -50%);
			width: 10px;
			height: 10px;
			background: #a213da;
			border-radius: 50%;
		}

		/* Custom Checkbox */
		.checkbox-group {
			margin: 1rem 0;
		}

		.custom-checkbox {
			display: flex;
			align-items: flex-start;
			gap: 0.8rem;
			cursor: pointer;
		}

		.custom-checkbox input {
			display: none;
		}

		.checkmark {
			width: 20px;
			height: 20px;
			border: 1px solid rgba(255, 255, 255, 0.3);
			border-radius: 4px;
			display: flex;
			align-items: center;
			justify-content: center;
			flex-shrink: 0;
			transition: all 0.3s;
			margin-top: 2px;
		}

		.custom-checkbox:hover .checkmark {
			border-color: rgba(255, 255, 255, 0.6);
		}

		.custom-checkbox input:checked + .checkmark {
			background: #a213da;
			border-color: #a213da;
		}

		.custom-checkbox input:checked + .checkmark::after {
			content: '✔';
			color: white;
			font-size: 12px;
		}

		.check-text {
			font-size: 0.75rem;
			color: rgba(255, 255, 255, 0.5);
			line-height: 1.5;
		}

		/* Dropzone */
		.file-upload-section {
			margin: 0.5rem 0;
		}

		.file-dropzone {
			border: 1px dashed rgba(255, 255, 255, 0.2);
			border-radius: 12px;
			padding: 2rem;
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			text-align: center;
			cursor: pointer;
			transition: all 0.3s;
			background: rgba(255, 255, 255, 0.01);
		}

		.file-dropzone:hover,
		.file-dropzone.drag-active {
			border-color: #a213da;
			background: rgba(162, 19, 218, 0.05);
		}

		.drop-content {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 0.5rem;
			pointer-events: none;
		}

		.drop-title {
			color: white;
			font-weight: 600;
			font-size: 1rem;
		}
		.drop-desc {
			color: rgba(255, 255, 255, 0.4);
			font-size: 0.8rem;
		}
		.file-chosen-text {
			color: #a213da;
			font-size: 0.85rem;
			font-weight: 600;
			margin-top: 0.5rem;
		}

		/* Buttons */
		.btn-primary {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			gap: 0.8rem;
			padding: 1rem 2rem;
			background: #a213da;
			color: white;
			border: none;
			border-radius: 99px;
			font-weight: 700;
			font-size: 0.9rem;
			text-transform: uppercase;
			letter-spacing: 0.05em;
			cursor: pointer;
			transition: all 0.3s;
		}

		.btn-primary:hover {
			background: #b515f2;
			transform: translateY(-2px);
			box-shadow: 0 10px 20px rgba(162, 19, 218, 0.3);
		}

		.btn-primary.success-variant {
			background: #28a745;
		}
		.btn-primary.success-variant:hover {
			background: #218838;
			box-shadow: 0 10px 20px rgba(40, 167, 69, 0.3);
		}

		.btn-primary svg {
			width: 18px;
			height: 18px;
		}

		.w-full {
			width: 100%;
		}

		.mt-6 {
			margin-top: 1.5rem;
		}

		.success-message {
			text-align: center;
			padding: 2rem 0;
		}

		.success-icon {
			width: 60px;
			height: 60px;
			border-radius: 50%;
			background: rgba(40, 167, 69, 0.1);
			color: #28a745;
			display: flex;
			align-items: center;
			justify-content: center;
			margin: 0 auto 1.5rem;
		}

		.success-icon svg {
			width: 30px;
			height: 30px;
		}

		.success-message h4 {
			font-size: 1.5rem;
			margin-bottom: 0.5rem;
		}

		.success-message p {
			color: rgba(255, 255, 255, 0.7);
		}

		/* Responsive */
		@media (max-width: 1024px) {
			.job-split-layout {
				grid-template-columns: 1fr;
				padding: 2rem 5%;
				gap: 3rem;
			}

			.job-info-column {
				max-width: 100%;
			}

			.form-card {
				position: static;
				padding: 2rem 1.5rem;
			}
		}
	</style>

	<script>
		const form1 = document.getElementById('app-form-1') as HTMLFormElement;
		const form2 = document.getElementById('app-form-final') as HTMLFormElement;
		const step1 = document.getElementById('form-step-1');
		const step2 = document.getElementById('form-step-2');
		const btnBack = document.querySelector('.btn-back-step');
		const fileInput = document.getElementById('cv_upload') as HTMLInputElement;
		const fileNameDisplay = document.getElementById('file-name-display');
		const formSuccessMsg = document.getElementById('form-success-msg');
		const btnReset = document.querySelector('.reset-form-btn');

		// Collect Form Data
		let formData = new FormData();

		// Step 1 -> Step 2
		if (form1) {
			form1.addEventListener('submit', e => {
				e.preventDefault();

				// Save Step 1 data
				const data = new FormData(form1);
				for (const [key, value] of data.entries()) {
					formData.set(key, value);
				}

				// Switch View
				step1?.classList.remove('active');
				step2?.classList.add('active');
			});
		}

		// Back button Step 2 -> Step 1
		if (btnBack) {
			btnBack.addEventListener('click', () => {
				step2?.classList.remove('active');
				step1?.classList.add('active');
			});
		}

		// File Upload Name Display
		if (fileInput && fileNameDisplay) {
			fileInput.addEventListener('change', e => {
				const target = e.target as HTMLInputElement;
				if (target.files && target.files.length > 0) {
					fileNameDisplay.textContent = `Wybrano: ${target.files[0].name}`;
					formData.set('cvFile', target.files[0]);
				} else {
					fileNameDisplay.textContent = '';
					formData.delete('cvFile');
				}
			});

			// Drag and Drop styles
			const dropzone = document.querySelector('.file-dropzone');
			if (dropzone) {
				['dragover', 'dragenter'].forEach(evt => {
					dropzone.addEventListener(evt, e => {
						e.preventDefault();
						dropzone.classList.add('drag-active');
					});
				});
				['dragleave', 'dragend', 'drop'].forEach(evt => {
					dropzone.addEventListener(evt, e => {
						e.preventDefault();
						dropzone.classList.remove('drag-active');
					});
				});
				dropzone.addEventListener('drop', e => {
					const dragEvent = e as DragEvent;
					if (dragEvent.dataTransfer?.files.length) {
						fileInput.files = dragEvent.dataTransfer.files;
						fileNameDisplay.textContent = `Wybrano: ${fileInput.files[0].name}`;
						formData.set('cvFile', fileInput.files[0]);
					}
				});
			}
		}

		// Final Submit
		if (form2) {
			form2.addEventListener('submit', async e => {
				e.preventDefault();

				const submitBtn = document.getElementById('btn-submit-form') as HTMLButtonElement;
				const originalText = submitBtn.innerHTML;

				// Append Step 2 data
				const data = new FormData(form2);
				for (const [key, value] of data.entries()) {
					if (key !== 'cvFile') {
						formData.set(key, value);
					}
				}

				// Append job title
				const jobTitleEl = document.querySelector('.job-title');
				if (jobTitleEl && jobTitleEl.textContent) {
					formData.set('jobTitle', jobTitleEl.textContent.trim());
				}

				// UX Fake Loading -> Real Loading
				submitBtn.innerHTML =
					'Wysyłanie... <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="animate-spin"><circle cx="12" cy="12" r="10"></circle><path d="M12 2v4"></path></svg>';
				submitBtn.style.opacity = '0.7';
				submitBtn.disabled = true;

				try {
					const response = await fetch('https://hook.eu1.make.com/u82oxrbzg7ncmv0admsdmmrq6pvyfxte', {
						method: 'POST',
						body: formData,
					});

					if (!response.ok) {
						throw new Error('Network response was not ok');
					}

					// Show Success
					Array.from(form2.children).forEach(child => {
						if (child.id !== 'form-success-msg') {
							(child as HTMLElement).style.display = 'none';
						}
					});
					if (formSuccessMsg) formSuccessMsg.style.display = 'block';
				} catch (err) {
					console.error('Form submission error:', err);
					alert('Wystąpił błąd podczas wysyłania formularza. Spróbuj ponownie później.');
				} finally {
					// Reset button state for next time
					submitBtn.innerHTML = originalText;
					submitBtn.style.opacity = '1';
					submitBtn.disabled = false;
					form1.reset();
					form2.reset();
					if (fileNameDisplay) fileNameDisplay.textContent = '';
					formData = new FormData();
				}
			});
		}

		// Reset Form Button
		if (btnReset) {
			btnReset.addEventListener('click', () => {
				if (formSuccessMsg) formSuccessMsg.style.display = 'none';
				Array.from(form2.children).forEach(child => {
					if (child.id !== 'form-success-msg') {
						(child as HTMLElement).style.display = '';
					}
				});
				step2?.classList.remove('active');
				step1?.classList.add('active');
			});
		}
	</script>
</Layout>
