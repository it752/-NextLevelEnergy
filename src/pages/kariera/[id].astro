---
import Layout from '../../layouts/Layout.astro';
import { jobOffers } from '../../data/jobs';

export function getStaticPaths() {
	return jobOffers.map(offer => ({
		params: { id: offer.id },
		props: { offer },
	}));
}

const { offer } = Astro.props;
---

<Layout title={`${offer.title} - Kariera | Level Up`} description={offer.description}>
	<nav class="navbar-simple">
		<a href="/" class="back-link">
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
				<path d="M19 12H5M12 19l-7-7 7-7"></path>
			</svg>
			Wróć na stronę główną
		</a>
	</nav>

	<main class="job-detail-page">
		<div class="job-header">
			<span class="nf-badge">REKRUTACJA</span>
			<h1 class="job-title">{offer.title}</h1>
			<div class="job-meta">
				<span class="meta-item">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
						><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg
					>
					{offer.salary}
				</span>
				<span class="meta-item">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
						><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"
						></circle></svg
					>
					{offer.location}
				</span>
			</div>
		</div>

		<div class="job-content">
			<section class="job-section">
				<h2>Opis stanowiska</h2>
				<p>{offer.description}</p>
			</section>

			<section class="job-section">
				<h2>Zakres obowiązków</h2>
				<ul>
					{offer.responsibilities.map((item: string) => <li>{item}</li>)}
				</ul>
			</section>

			<section class="job-section">
				<h2>Nasze wymagania</h2>
				<ul>
					{offer.requirements.map((item: string) => <li>{item}</li>)}
				</ul>
			</section>

			<section class="application-form">
				<h2>Aplikuj na to stanowisko</h2>
				<p>
					Aby wziąć udział w rekrutacji, wyślij swoje CV na adres e-mail: <strong
						>rekrutacja@levelup.pl</strong
					> z dopiskiem <em>"{offer.title}"</em> w tytule wiadomości.
				</p>
				<p class="form-note">
					Pełna integracja z formularzem aplikacyjnym (Sanity) zostanie niedługo ukończona.
				</p>
				<a href={`mailto:rekrutacja@levelup.pl?subject=Aplikacja: ${offer.title}`} class="btn-primary">
					Aplikuj e-mailowo
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
						><path d="M5 12h14M12 5l7 7-7 7"></path></svg
					>
				</a>
			</section>
		</div>
	</main>
</Layout>

<style>
	.navbar-simple {
		padding: 2rem 5%;
		background: #0b111d;
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
	}
	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		color: rgba(255, 255, 255, 0.7);
		text-decoration: none;
		font-weight: 500;
		transition: color 0.3s;
	}
	.back-link:hover {
		color: white;
	}
	.job-detail-page {
		background: #0b111d;
		min-height: 100vh;
		color: white;
		padding-bottom: 5rem;
	}
	.nf-badge {
		display: inline-block;
		background: rgba(162, 19, 218, 0.2);
		color: #a213da;
		padding: 0.3rem 0.8rem;
		border-radius: 99px;
		font-size: 0.75rem;
		font-weight: 800;
		letter-spacing: 0.1em;
		margin-bottom: 1rem;
		border: 1px solid rgba(162, 19, 218, 0.4);
	}
	.job-header {
		max-width: 800px;
		margin: 0 auto;
		padding: 4rem 2rem;
		text-align: center;
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
	}
	.job-title {
		font-size: clamp(2.5rem, 5vw, 4rem);
		font-weight: 900;
		line-height: 1.1;
		margin-bottom: 1.5rem;
	}
	.job-meta {
		display: flex;
		justify-content: center;
		gap: 2rem;
		flex-wrap: wrap;
	}
	.meta-item {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: rgba(255, 255, 255, 0.7);
		font-size: 1.1rem;
	}
	.meta-item svg {
		width: 20px;
		height: 20px;
		color: #a213da;
	}
	.job-content {
		max-width: 800px;
		margin: 0 auto;
		padding: 3rem 2rem;
	}
	.job-section {
		margin-bottom: 3rem;
	}
	.job-section h2 {
		font-size: 1.5rem;
		font-weight: 700;
		margin-bottom: 1.5rem;
		color: #a213da;
	}
	.job-section p {
		color: rgba(255, 255, 255, 0.8);
		line-height: 1.7;
		font-size: 1.1rem;
	}
	.job-section ul {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	.job-section ul li {
		position: relative;
		padding-left: 1.5rem;
		color: rgba(255, 255, 255, 0.8);
		line-height: 1.5;
		font-size: 1.05rem;
	}
	.job-section ul li::before {
		content: '→';
		position: absolute;
		left: 0;
		color: #a213da;
		font-weight: bold;
	}

	.application-form {
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid rgba(255, 255, 255, 0.05);
		border-radius: 16px;
		padding: 3rem;
		text-align: center;
		margin-top: 4rem;
	}
	.application-form h2 {
		font-size: 2rem;
		font-weight: 800;
		margin-bottom: 1rem;
	}
	.application-form p {
		color: rgba(255, 255, 255, 0.7);
		margin-bottom: 1.5rem;
		line-height: 1.6;
	}
	.form-note {
		font-size: 0.85rem !important;
		color: rgba(255, 255, 255, 0.4) !important;
		margin-bottom: 2.5rem !important;
	}
	.btn-primary {
		display: inline-flex;
		align-items: center;
		gap: 0.8rem;
		padding: 1rem 2rem;
		background: #a213da;
		color: white;
		text-decoration: none;
		font-weight: 700;
		border-radius: 99px;
		transition: all 0.3s;
	}
	.btn-primary:hover {
		background: #c026d3;
		transform: translateY(-2px);
		box-shadow: 0 10px 20px rgba(162, 19, 218, 0.3);
	}
	.btn-primary svg {
		width: 20px;
		height: 20px;
	}
</style>
