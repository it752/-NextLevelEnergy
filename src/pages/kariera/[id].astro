---
import Layout from '../../layouts/Layout.astro';
import { jobOffers, type JobOffer } from '../../data/jobs';

export function getStaticPaths() {
	return jobOffers.map(job => ({
		params: { id: job.id },
		props: { job },
	}));
}

interface Props {
	job: JobOffer;
}

const { job } = Astro.props;
---

<Layout title={`${job.title} - Kariera | The Next Level`}>
	<div class="page-wrapper">
		<!-- Header / Nav Area -->
		<header class="page-header">
			<a href="/#kariera" class="back-link" aria-label="Wróć do wszystkich ofert">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M19 12H5M12 19l-7-7 7-7"></path>
				</svg>
				Wróć do listy ofert
			</a>
			<div class="logo-area">
				<span class="nf-badge">NEXT LEVEL KARIERA</span>
			</div>
		</header>

		<main class="landing-container">
			<div class="grid-layout">
				<!-- Left Column: Job Details -->
				<section class="job-info-section">
					<h1 class="job-title">{job.title}</h1>

					<div class="meta-tags">
						<span class="meta-tag department">Dział: {job.department}</span>
						<span class="meta-tag salary">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
							</svg>
							{job.salary}
						</span>
						<span class="meta-tag location">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
								<circle cx="12" cy="10" r="3"></circle>
							</svg>
							{job.location}
						</span>
					</div>

					<div class="job-description">
						<p>{job.description}</p>
					</div>

					<div class="content-block">
						<h3>Zakres obowiązków</h3>
						<ul class="custom-list">
							{job.responsibilities.map(item => <li>{item}</li>)}
						</ul>
					</div>

					<div class="content-block">
						<h3>Nasze wymagania</h3>
						<ul class="custom-list">
							{job.requirements.map(item => <li>{item}</li>)}
						</ul>
					</div>
				</section>

				<!-- Right Column: Application Form -->
				<section class="application-section">
					<div class="form-container">
						<div class="form-intro">
							<h2>Aplikuj na stanowisko</h2>
							<p>
								Wypełnij poniższy formularz, a my skontaktujemy się z Tobą najszybciej jak to możliwe.
							</p>
						</div>

						<form id="standalone-app-form" class="app-form">
							<!-- Step 1 Data -->
							<div class="form-grid">
								<div class="input-wrapper">
									<label for="app_name">Imię</label>
									<input type="text" id="app_name" required placeholder="Jan" />
								</div>
								<div class="input-wrapper">
									<label for="app_surname">Nazwisko</label>
									<input type="text" id="app_surname" required placeholder="Kowalski" />
								</div>
							</div>

							<div class="input-wrapper">
								<label for="app_email">Adres E-mail</label>
								<input type="email" id="app_email" required placeholder="jan@example.com" />
							</div>

							<div class="form-grid">
								<div class="input-wrapper">
									<label for="app_phone">Telefon</label>
									<input type="tel" id="app_phone" required placeholder="+48 000 000 000" />
								</div>
								<div class="input-wrapper">
									<label for="app_city">Miasto</label>
									<input type="text" id="app_city" required placeholder="Warszawa" />
								</div>
							</div>

							<!-- Step 2 Data -->
							<div class="divider"></div>

							<div class="input-wrapper select-group">
								<label for="app_type">Preferowany typ współpracy</label>
								<div class="custom-dropdown-container" id="collab-dropdown-container">
									<button
										type="button"
										class="custom-dropdown-trigger"
										id="collab-filter-trigger"
										aria-haspopup="listbox"
										aria-expanded="false">
										<div class="trigger-content">
											<span id="selected-collab-text">Wybierz formę zatrudnienia</span>
										</div>
										<svg
											class="dropdown-chevron"
											viewBox="0 0 24 24"
											fill="none"
											stroke="currentColor"
											stroke-width="2">
											<path d="M6 9l6 6 6-6"></path>
										</svg>
									</button>

									<div class="custom-dropdown-list" role="listbox" id="collab-dropdown-list">
										<button
											type="button"
											class="dropdown-option"
											data-value="b2b"
											role="option"
											aria-selected="false">B2B</button
										>
										<button
											type="button"
											class="dropdown-option"
											data-value="uz"
											role="option"
											aria-selected="false">Umowa Zlecenie</button
										>
										<button
											type="button"
											class="dropdown-option"
											data-value="uop"
											role="option"
											aria-selected="false">Umowa o Pracę</button
										>
									</div>
									<input type="hidden" id="app_type" name="app_type" required />
								</div>
							</div>

							<div class="radio-section">
								<p class="radio-label">Prawo jazdy kategorii B:</p>
								<div class="radio-group">
									<label class="radio-custom">
										<input type="radio" name="driver_license" value="yes" required checked />
										<span class="radio-mark"></span>
										Posiadam
									</label>
									<label class="radio-custom">
										<input type="radio" name="driver_license" value="no" required />
										<span class="radio-mark"></span>
										Nie posiadam
									</label>
								</div>
							</div>

							<div class="file-upload-section">
								<label class="file-dropzone" for="cv_upload">
									<input type="file" id="cv_upload" accept=".pdf,.doc,.docx" required hidden />
									<div class="drop-content">
										<svg
											viewBox="0 0 24 24"
											fill="none"
											stroke="#A213DA"
											stroke-width="2"
											width="32"
											height="32">
											<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
											<polyline points="17 8 12 3 7 8"></polyline>
											<line x1="12" y1="3" x2="12" y2="15"></line>
										</svg>
										<span class="drop-title">Załącz CV</span>
										<span class="drop-desc">Dostępne formaty: pdf, doc, docx</span>
										<span id="file-name-display" class="file-chosen-text"></span>
									</div>
								</label>
							</div>

							<div class="checkbox-group">
								<label class="custom-checkbox">
									<input type="checkbox" required />
									<span class="checkmark"></span>
									<span class="check-text">
										Wyrażam zgodę na przetwarzanie moich danych osobowych przez The Next Level w
										celu prowadzenia rekrutacji na aplikowane stanowisko.
									</span>
								</label>
							</div>

							<button type="submit" id="btn-submit-form" class="btn-submit">
								Aplikuj
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"></path>
								</svg>
							</button>
						</form>
					</div>
				</section>
			</div>
		</main>
	</div>
</Layout>

<style>
	/* Global Reset for this view */
	:global(body) {
		background-color: #0b111d;
		color: white;
		margin: 0;
		font-family: 'Inter', sans-serif;
	}

	.page-wrapper {
		min-height: 100vh;
		position: relative;
		overflow-x: hidden;
		background:
			radial-gradient(circle at top right, rgba(162, 19, 218, 0.1) 0%, transparent 60%),
			radial-gradient(circle at bottom left, rgba(0, 71, 255, 0.05) 0%, transparent 50%);
	}

	.page-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 2rem 5%;
		max-width: 1600px;
		margin: 0 auto;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		color: rgba(255, 255, 255, 0.7);
		text-decoration: none;
		font-weight: 600;
		font-size: 0.95rem;
		transition: all 0.3s;
	}
	.back-link:hover {
		color: #a213da;
		transform: translateX(-5px);
	}
	.back-link svg {
		width: 18px;
		height: 18px;
	}

	.nf-badge {
		border: 1px solid rgba(162, 19, 218, 0.5);
		background: rgba(162, 19, 218, 0.1);
		padding: 0.4rem 1.2rem;
		border-radius: 99px;
		font-size: 0.75rem;
		font-weight: 800;
		color: #a213da;
		letter-spacing: 0.1em;
	}

	.landing-container {
		max-width: 1400px;
		margin: 0 auto;
		padding: 2rem 5% 5rem;
	}

	.grid-layout {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
	}

	/* --- LEFT COLUMN: INFO --- */
	.job-info-section {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.job-title {
		font-size: 3.5rem;
		font-weight: 800;
		line-height: 1.1;
		margin: 0;
		background: linear-gradient(135deg, #fff 0%, rgba(255, 255, 255, 0.7) 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.meta-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.meta-tag {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.6rem 1.2rem;
		border-radius: 99px;
		font-size: 0.9rem;
		font-weight: 600;
		background: rgba(255, 255, 255, 0.05);
	}

	.meta-tag.department {
		background: rgba(255, 255, 255, 0.1);
		color: white;
	}

	.meta-tag.salary {
		color: #a213da;
		background: rgba(162, 19, 218, 0.1);
		border: 1px solid rgba(162, 19, 218, 0.3);
	}

	.meta-tag.location {
		color: rgba(255, 255, 255, 0.8);
	}
	.meta-tag svg {
		width: 16px;
		height: 16px;
	}

	.job-description {
		font-size: 1.1rem;
		line-height: 1.7;
		color: rgba(255, 255, 255, 0.8);
	}

	.content-block h3 {
		font-size: 1.4rem;
		font-weight: 700;
		margin-bottom: 1.5rem;
		color: white;
	}

	.custom-list {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.custom-list li {
		color: rgba(255, 255, 255, 0.7);
		line-height: 1.5;
		position: relative;
		padding-left: 1.8rem;
		font-size: 1rem;
	}

	.custom-list li::before {
		content: '✓';
		color: #a213da;
		font-size: 1.2rem;
		font-weight: bold;
		position: absolute;
		left: 0;
		top: -2px;
	}

	/* --- RIGHT COLUMN: FORM --- */
	.application-section {
		display: flex;
		justify-content: center;
	}

	.form-container {
		background: rgba(15, 23, 42, 0.6);
		border: 1px solid rgba(255, 255, 255, 0.05);
		border-radius: 24px;
		padding: 3rem;
		width: 100%;
		max-width: 600px;
		box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
		backdrop-filter: blur(20px);
	}

	.form-intro {
		margin-bottom: 2.5rem;
	}
	.form-intro h2 {
		font-size: 2rem;
		font-weight: 800;
		margin: 0 0 0.5rem 0;
	}
	.form-intro p {
		color: rgba(255, 255, 255, 0.6);
		font-size: 0.95rem;
		margin: 0;
		line-height: 1.5;
	}

	.app-form {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.form-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
	}

	.input-wrapper {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		width: 100%;
	}

	.input-wrapper label {
		font-size: 0.85rem;
		color: rgba(255, 255, 255, 0.8);
		font-weight: 600;
	}

	.input-wrapper input,
	.input-wrapper select {
		width: 100%;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 12px;
		padding: 1rem 1.2rem;
		font-size: 0.95rem;
		color: white;
		transition: all 0.3s;
	}

	.input-wrapper input:focus,
	.input-wrapper select:focus {
		outline: none;
		border-color: #a213da;
		background: rgba(162, 19, 218, 0.05);
		box-shadow: 0 0 0 4px rgba(162, 19, 218, 0.1);
	}

	.input-wrapper input::placeholder {
		color: rgba(255, 255, 255, 0.2);
	}

	/* Custom Dropdown Styling */
	.custom-dropdown-container {
		position: relative;
		width: 100%;
	}

	.custom-dropdown-trigger {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: 100%;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 12px;
		padding: 1rem 1.2rem;
		cursor: pointer;
		transition: all 0.3s;
		color: rgba(255, 255, 255, 0.4);
		font-weight: 500;
		font-size: 0.95rem;
		text-align: left;
	}

	.custom-dropdown-container.has-selection .custom-dropdown-trigger {
		color: white;
	}

	.custom-dropdown-trigger:hover,
	.custom-dropdown-container.is-open .custom-dropdown-trigger {
		border-color: #a213da;
		background: rgba(162, 19, 218, 0.05);
		box-shadow: 0 0 0 4px rgba(162, 19, 218, 0.1);
	}

	.trigger-content {
		display: flex;
		align-items: center;
		gap: 0.8rem;
		width: 100%;
		overflow: hidden;
	}

	.dropdown-chevron {
		width: 18px;
		height: 18px;
		color: rgba(255, 255, 255, 0.5);
		transition: transform 0.3s;
		flex-shrink: 0;
	}

	.custom-dropdown-container.is-open .dropdown-chevron {
		transform: rotate(180deg);
		color: #a213da;
	}

	.custom-dropdown-list {
		position: absolute;
		top: calc(100% + 0.5rem);
		left: 0;
		width: 100%;
		background: #0b111d;
		border: 1px solid rgba(162, 19, 218, 0.3);
		border-radius: 16px;
		box-shadow: 0 10px 40px rgba(0, 0, 0, 0.8);
		overflow: hidden;
		z-index: 100;
		opacity: 0;
		visibility: hidden;
		transform: translateY(-10px);
		transition: all 0.3s cubic-bezier(0.19, 1, 0.22, 1);
		display: flex;
		flex-direction: column;
	}

	.custom-dropdown-container.is-open .custom-dropdown-list {
		opacity: 1;
		visibility: visible;
		transform: translateY(0);
	}

	.dropdown-option {
		width: 100%;
		text-align: left;
		background: none;
		border: none;
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
		padding: 1rem 1.5rem;
		color: rgba(255, 255, 255, 0.7);
		font-size: 0.95rem;
		cursor: pointer;
		transition: all 0.2s;
	}

	.dropdown-option:last-child {
		border-bottom: none;
	}

	.dropdown-option:hover {
		background: rgba(162, 19, 218, 0.1);
		color: white;
		padding-left: 2rem;
	}

	.dropdown-option.is-selected {
		background: rgba(162, 19, 218, 0.15);
		color: #a213da;
		font-weight: 700;
	}

	.divider {
		height: 1px;
		background: rgba(255, 255, 255, 0.05);
		margin: 1rem 0;
	}

	/* Radio Buttons */
	.radio-section {
		margin: 0.5rem 0;
	}
	.radio-label {
		font-size: 0.9rem;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.8);
		margin-bottom: 0.8rem;
	}

	.radio-group {
		display: flex;
		gap: 2rem;
	}

	.radio-custom,
	.custom-checkbox {
		display: flex;
		align-items: flex-start;
		gap: 0.8rem;
		position: relative;
		cursor: pointer;
		font-size: 0.95rem;
		color: rgba(255, 255, 255, 0.8);
		user-select: none;
	}

	.radio-custom input,
	.custom-checkbox input {
		position: absolute;
		opacity: 0;
		cursor: pointer;
	}

	.radio-mark {
		width: 20px;
		height: 20px;
		border: 1px solid rgba(255, 255, 255, 0.3);
		border-radius: 50%;
		position: relative;
		margin-top: 2px;
		flex-shrink: 0;
		transition: all 0.2s;
	}

	.radio-custom:hover .radio-mark {
		border-color: rgba(255, 255, 255, 0.6);
	}

	.radio-mark::after {
		content: '';
		position: absolute;
		display: none;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: #a213da;
	}

	.radio-custom input:checked ~ .radio-mark {
		border-color: #a213da;
	}
	.radio-custom input:checked ~ .radio-mark::after {
		display: block;
	}

	/* Checkbox */
	.checkmark {
		width: 20px;
		height: 20px;
		border: 1px solid rgba(255, 255, 255, 0.3);
		border-radius: 6px;
		position: relative;
		margin-top: 2px;
		flex-shrink: 0;
		transition: all 0.2s;
	}

	.custom-checkbox:hover .checkmark {
		border-color: rgba(255, 255, 255, 0.6);
	}

	.checkmark::after {
		content: '';
		position: absolute;
		display: none;
		left: 6px;
		top: 2px;
		width: 5px;
		height: 10px;
		border: solid white;
		border-width: 0 2px 2px 0;
		transform: rotate(45deg);
	}

	.custom-checkbox input:checked ~ .checkmark {
		background-color: #a213da;
		border-color: #a213da;
	}
	.custom-checkbox input:checked ~ .checkmark::after {
		display: block;
	}

	.check-text {
		font-size: 0.8rem;
		color: rgba(255, 255, 255, 0.5);
		line-height: 1.5;
	}

	/* File Upload Dropzone */
	.file-upload-section {
		margin: 0.5rem 0;
	}

	.file-dropzone {
		border: 1px dashed rgba(255, 255, 255, 0.2);
		border-radius: 16px;
		padding: 2.5rem 2rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		cursor: pointer;
		transition: all 0.3s;
		background: rgba(255, 255, 255, 0.01);
	}

	.file-dropzone:hover {
		border-color: #a213da;
		background: rgba(162, 19, 218, 0.05);
	}

	.drop-content {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		pointer-events: none;
	}

	.drop-title {
		color: white;
		font-weight: 600;
		font-size: 1rem;
	}
	.drop-desc {
		color: rgba(255, 255, 255, 0.4);
		font-size: 0.8rem;
	}
	.file-chosen-text {
		color: #a213da;
		font-size: 0.85rem;
		font-weight: 600;
		margin-top: 0.5rem;
	}

	/* Submit Button */
	.btn-submit {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.8rem;
		padding: 1.2rem;
		background: #a213da;
		color: white;
		border: none;
		border-radius: 99px;
		font-weight: 700;
		font-size: 1rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		cursor: pointer;
		transition: all 0.3s;
		margin-top: 1rem;
		width: 100%;
	}

	.btn-submit:hover {
		background: #b515f2;
		transform: translateY(-2px);
		box-shadow: 0 10px 20px rgba(162, 19, 218, 0.3);
	}

	.btn-submit svg {
		width: 18px;
		height: 18px;
	}

	/* RESPONSIVE DESIGN */
	@media (max-width: 1024px) {
		.grid-layout {
			grid-template-columns: 1fr;
			gap: 3rem;
		}

		.job-title {
			font-size: 2.8rem;
		}

		.form-container {
			padding: 2.5rem 2rem;
		}
	}

	@media (max-width: 768px) {
		.form-grid {
			grid-template-columns: 1fr;
		}

		.job-title {
			font-size: 2.2rem;
		}

		.form-container {
			padding: 2rem 1.5rem;
		}

		.page-header {
			padding: 1.5rem 5%;
		}
	}
</style>

<script>
	const fileInput = document.getElementById('cv_upload') as HTMLInputElement;
	const fileNameDisplay = document.getElementById('file-name-display');

	// File Upload Display
	if (fileInput && fileNameDisplay) {
		fileInput.addEventListener('change', e => {
			const target = e.target as HTMLInputElement;
			if (target.files && target.files.length > 0) {
				fileNameDisplay.textContent = `Wybrano plik: ${target.files[0].name}`;
			} else {
				fileNameDisplay.textContent = '';
			}
		});
	}

	// Custom Dropdown Logic
	const dropdownContainer = document.getElementById('collab-dropdown-container');
	const dropdownTrigger = document.getElementById('collab-filter-trigger');
	const dropdownList = document.getElementById('collab-dropdown-list');
	const selectedText = document.getElementById('selected-collab-text');
	const hiddenInput = document.getElementById('app_type') as HTMLInputElement;

	if (dropdownContainer && dropdownTrigger && dropdownList && selectedText && hiddenInput) {
		const options = dropdownList.querySelectorAll('.dropdown-option');

		// Toggle dropdown
		dropdownTrigger.addEventListener('click', e => {
			e.preventDefault();
			const isOpen = dropdownContainer.classList.contains('is-open');

			if (isOpen) {
				dropdownContainer.classList.remove('is-open');
				dropdownTrigger.setAttribute('aria-expanded', 'false');
			} else {
				dropdownContainer.classList.add('is-open');
				dropdownTrigger.setAttribute('aria-expanded', 'true');
			}
		});

		// Select option
		options.forEach(option => {
			option.addEventListener('click', e => {
				e.preventDefault();

				options.forEach(opt => {
					opt.classList.remove('is-selected');
					opt.setAttribute('aria-selected', 'false');
				});

				const target = e.target as HTMLElement;
				target.classList.add('is-selected');
				target.setAttribute('aria-selected', 'true');

				const value = target.getAttribute('data-value');
				if (value) {
					hiddenInput.value = value;
					// Trigger validation by dispatching event
					hiddenInput.dispatchEvent(new Event('change'));
					selectedText.textContent = target.textContent;
					dropdownContainer.classList.add('has-selection');
				}

				dropdownContainer.classList.remove('is-open');
				dropdownTrigger.setAttribute('aria-expanded', 'false');
			});
		});

		// Close on outside click
		document.addEventListener('click', e => {
			if (!dropdownContainer.contains(e.target as Node)) {
				dropdownContainer.classList.remove('is-open');
				dropdownTrigger.setAttribute('aria-expanded', 'false');
			}
		});
	}

	// Final Submission Fake Logic
	document.getElementById('standalone-app-form')?.addEventListener('submit', e => {
		e.preventDefault();

		// If custom dropdown hasn't been selected yet, alert user
		if (!hiddenInput.value) {
			alert('Prosimy o wybranie formy współpracy.');
			if (dropdownContainer) dropdownContainer.classList.add('is-open');
			return;
		}

		const submitBtn = document.getElementById('btn-submit-form') as HTMLButtonElement;

		// UX Fake Loading
		const originalText = submitBtn.innerHTML;
		submitBtn.innerHTML = 'Wysyłanie...';
		submitBtn.style.opacity = '0.7';
		submitBtn.style.pointerEvents = 'none';

		setTimeout(() => {
			submitBtn.innerHTML = 'Wysłano pomyślnie! ✔';
			submitBtn.style.background = '#28a745';
			submitBtn.style.opacity = '1';

			// Optional Reset after success
			setTimeout(() => {
				submitBtn.innerHTML = originalText;
				submitBtn.style.background = '';
				submitBtn.style.pointerEvents = 'all';

				// Clear form
				(document.getElementById('standalone-app-form') as HTMLFormElement).reset();
				if (fileNameDisplay) fileNameDisplay.textContent = '';

				// Reset custom dropdown
				hiddenInput.value = '';
				if (selectedText) selectedText.textContent = 'Wybierz formę zatrudnienia';
				if (dropdownContainer) dropdownContainer.classList.remove('has-selection');
				const dropdownOptions = document.querySelectorAll('.dropdown-option');
				dropdownOptions.forEach(opt => {
					opt.classList.remove('is-selected');
					opt.setAttribute('aria-selected', 'false');
				});
			}, 3000);
		}, 1500);
	});
</script>
